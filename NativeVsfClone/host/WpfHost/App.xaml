<Application x:Class="WpfHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
   <Application.Resources>
       <FontFamily x:Key="Font.Body">Segoe UI Variable Text</FontFamily>
       <FontFamily x:Key="Font.Display">Segoe UI Variable Display</FontFamily>

       <SolidColorBrush x:Key="Color.Surface" Color="#F7F5FF"/>
       <SolidColorBrush x:Key="Color.SurfaceAlt" Color="#EFEBFF"/>
       <SolidColorBrush x:Key="Color.Card" Color="#FDFCFF"/>
       <SolidColorBrush x:Key="Color.CardStrong" Color="#FFFFFF"/>
       <SolidColorBrush x:Key="Color.Border" Color="#ECE8F5"/>
       <SolidColorBrush x:Key="Color.BorderStrong" Color="#D8D0EE"/>
       <SolidColorBrush x:Key="Color.Text" Color="#0F172A"/>
       <SolidColorBrush x:Key="Color.TextMuted" Color="#475569"/>
       <SolidColorBrush x:Key="Color.TextSubtle" Color="#94A3B8"/>
       <SolidColorBrush x:Key="Color.Primary" Color="#5B21B6"/>
       <SolidColorBrush x:Key="Color.PrimaryHover" Color="#4C1D95"/>
       <SolidColorBrush x:Key="Color.PrimaryPressed" Color="#3B0764"/>
       <SolidColorBrush x:Key="Color.PrimaryText" Color="#FFFFFF"/>
       <SolidColorBrush x:Key="Color.Success" Color="#059669"/>
       <SolidColorBrush x:Key="Color.Warning" Color="#D97706"/>
       <SolidColorBrush x:Key="Color.Error" Color="#DC2626"/>
       <SolidColorBrush x:Key="Color.TabBg" Color="#F0EBFF"/>
       <SolidColorBrush x:Key="Color.TabActive" Color="#FFFFFF"/>
       <SolidColorBrush x:Key="Color.NavRailBg" Color="#1C1040"/>
       <SolidColorBrush x:Key="Color.NavItemBg" Color="#2D1F5E"/>
       <SolidColorBrush x:Key="Color.NavItemActiveBg" Color="#5B21B6"/>
       <SolidColorBrush x:Key="Color.NavItemText" Color="#A899D4"/>
       <SolidColorBrush x:Key="Color.NavItemActiveText" Color="#F3F0FF"/>
       <SolidColorBrush x:Key="Color.OnboardingBarBg" Color="#EDE9FE"/>
       <SolidColorBrush x:Key="Color.OnboardingBarBorder" Color="#DDD6FE"/>
       <SolidColorBrush x:Key="Color.OnboardingBarTitle" Color="#2E1065"/>
       <SolidColorBrush x:Key="Color.OnboardingBarBody" Color="#4C1D95"/>
       <SolidColorBrush x:Key="Color.BadgeNeutralBg" Color="#EFF3F9"/>
       <SolidColorBrush x:Key="Color.BadgeNeutralText" Color="#43586E"/>
       <SolidColorBrush x:Key="Color.RenderShellBg" Color="#1E1B4B"/>
       <SolidColorBrush x:Key="Color.RenderShellBorder" Color="#4338CA"/>
       <SolidColorBrush x:Key="Color.StatusBarBg" Color="#1E1B4B"/>
       <SolidColorBrush x:Key="Color.StatusBarBorder" Color="#4338CA"/>
       <SolidColorBrush x:Key="Color.StatusBarLabel" Color="#C4B5FD"/>
       <SolidColorBrush x:Key="Color.StatusBarValue" Color="#EDE9FE"/>
       <SolidColorBrush x:Key="Color.PanelInfoBg" Color="#EDE9FE"/>
       <SolidColorBrush x:Key="Color.PanelInfoBorder" Color="#DDD6FE"/>
       <SolidColorBrush x:Key="Color.PanelInfoText" Color="#1E1B4B"/>
       <SolidColorBrush x:Key="Color.PanelInfoAltBg" Color="#F5F3FF"/>
       <SolidColorBrush x:Key="Color.PanelInfoAltBorder" Color="#E9D5FF"/>
       <SolidColorBrush x:Key="Color.PanelInfoAltText" Color="#2E1065"/>
       <SolidColorBrush x:Key="Color.PanelSuccessBg" Color="#EEF6EF"/>
       <SolidColorBrush x:Key="Color.PanelSuccessBorder" Color="#BFDCC2"/>
       <SolidColorBrush x:Key="Color.PanelSuccessTitle" Color="#1E5130"/>
       <SolidColorBrush x:Key="Color.PanelSuccessText" Color="#2C6A3F"/>
       <SolidColorBrush x:Key="Color.PanelWarningBg" Color="#FFF8EE"/>
       <SolidColorBrush x:Key="Color.PanelWarningBorder" Color="#F3D2A7"/>
       <SolidColorBrush x:Key="Color.PanelWarningText" Color="#7C4012"/>
       <SolidColorBrush x:Key="Color.PanelErrorBg" Color="#FFF6F6"/>
       <SolidColorBrush x:Key="Color.PanelErrorBorder" Color="#F0B7B7"/>
       <SolidColorBrush x:Key="Color.PanelErrorText" Color="#7F1D1D"/>
       <SolidColorBrush x:Key="Color.ValidationErrorText" Color="#B03030"/>
       <SolidColorBrush x:Key="Color.CardSoftBg" Color="#F8F7FF"/>
       <SolidColorBrush x:Key="Color.CardSoftBorder" Color="#E9D5FF"/>
       <SolidColorBrush x:Key="Color.CardSoftBorderStrong" Color="#DDD6FE"/>
       <SolidColorBrush x:Key="Color.Splitter" Color="#E2E8F0"/>
       <SolidColorBrush x:Key="Color.OverlayHintBg" Color="#D0101720"/>
       <SolidColorBrush x:Key="Color.OverlayHintBorder" Color="#5A7088"/>
       <SolidColorBrush x:Key="Color.OverlayHintText" Color="#E8F0F8"/>
       <SolidColorBrush x:Key="Color.DebugOverlayBg" Color="#EEFFFFFF"/>
       <SolidColorBrush x:Key="Color.DebugOverlayBorder" Color="#47627E"/>
       <SolidColorBrush x:Key="Color.DebugOverlayText" Color="#1A2530"/>
       <SolidColorBrush x:Key="Color.StepComplete" Color="#10B981"/>
       <SolidColorBrush x:Key="Color.StepPending" Color="#7C6FA8"/>
       <SolidColorBrush x:Key="Color.PanelBase" Color="#F3F7FD"/>
       <SolidColorBrush x:Key="Color.PanelElevated" Color="#FFFFFF"/>
       <SolidColorBrush x:Key="Color.PanelInset" Color="#EDF3FA"/>
       <SolidColorBrush x:Key="Color.FocusRing" Color="#7C3AED"/>
       <SolidColorBrush x:Key="Color.DisabledBg" Color="#F1F5F9"/>
       <SolidColorBrush x:Key="Color.DisabledText" Color="#94A3B8"/>
       <SolidColorBrush x:Key="Color.LogAreaBg" Color="#F8F9FF"/>
       <SolidColorBrush x:Key="Color.LogAreaBorder" Color="#E2E8F0"/>

       <LinearGradientBrush x:Key="Brush.PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
           <GradientStop Color="#5B21B6" Offset="0"/>
           <GradientStop Color="#7C3AED" Offset="1"/>
       </LinearGradientBrush>

       <LinearGradientBrush x:Key="Brush.NavActive" StartPoint="0,0" EndPoint="1,0">
           <GradientStop Color="#5B21B6" Offset="0"/>
           <GradientStop Color="#7C3AED" Offset="1"/>
       </LinearGradientBrush>

       <Thickness x:Key="Spacing.ControlPadding">10,6</Thickness>
       <Thickness x:Key="Spacing.InputPadding">8,5</Thickness>

       <Style TargetType="Window">
           <Setter Property="Background" Value="{StaticResource Color.Surface}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
           <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
           <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
           <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
       </Style>

       <Style TargetType="GroupBox">
           <Setter Property="Margin" Value="0,0,0,16"/>
           <Setter Property="Padding" Value="0"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="GroupBox">
                       <Border CornerRadius="16"
                               BorderBrush="{DynamicResource Color.Border}"
                               BorderThickness="1"
                               Background="{DynamicResource Color.CardStrong}">
                           <Border.Effect>
                               <DropShadowEffect Color="#7C3AED"
                                                 BlurRadius="24"
                                                 ShadowDepth="0"
                                                 Opacity="0.07"/>
                           </Border.Effect>
                           <StackPanel>
                               <Border CornerRadius="16,16,0,0"
                                       Padding="16,12,16,12"
                                       BorderBrush="{DynamicResource Color.Border}"
                                       BorderThickness="0,0,0,1">
                                   <Border.Background>
                                       <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                           <GradientStop Color="#F5F0FF" Offset="0"/>
                                           <GradientStop Color="#FDFCFF" Offset="1"/>
                                       </LinearGradientBrush>
                                   </Border.Background>
                                   <ContentPresenter ContentSource="Header"
                                                     RecognizesAccessKey="True"
                                                     TextBlock.FontWeight="SemiBold"
                                                     TextBlock.FontSize="13"
                                                     TextBlock.Foreground="{DynamicResource Color.Text}"/>
                               </Border>
                               <ContentPresenter Margin="16,14,16,16"/>
                           </StackPanel>
                       </Border>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style TargetType="Button">
           <Setter Property="Background" Value="{StaticResource Brush.PrimaryGradient}"/>
           <Setter Property="Foreground" Value="#FFFFFF"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Padding" Value="14,9"/>
           <Setter Property="FontWeight" Value="SemiBold"/>
           <Setter Property="MinHeight" Value="38"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="Root"
                               Background="{TemplateBinding Background}"
                               CornerRadius="10"
                               Padding="{TemplateBinding Padding}">
                           <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                               <Setter TargetName="Root" Property="Effect">
                                   <Setter.Value>
                                       <DropShadowEffect Color="#6D28D9"
                                                         BlurRadius="18"
                                                         ShadowDepth="0"
                                                         Opacity="0.45"/>
                                   </Setter.Value>
                               </Setter>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="Root" Property="Opacity" Value="0.75"/>
                           </Trigger>
                           <Trigger Property="IsKeyboardFocused" Value="True">
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.FocusRing}"/>
                               <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.DisabledBg}"/>
                               <Setter TargetName="Root" Property="Opacity" Value="1"/>
                               <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Primary}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="Root"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{DynamicResource Color.Primary}"
                               BorderThickness="1.5"
                               CornerRadius="10"
                               Padding="{TemplateBinding Padding}">
                           <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.CardSoftBg}"/>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.SurfaceAlt}"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.Border}"/>
                               <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style x:Key="TertiaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Primary}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="Root"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{DynamicResource Color.Border}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="{TemplateBinding Padding}">
                           <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.SurfaceAlt}"/>
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.BorderStrong}"/>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.Surface}"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.Border}"/>
                               <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
           <Setter Property="Background" Value="{StaticResource Color.PanelInset}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="Root"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{DynamicResource Color.Border}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="{TemplateBinding Padding}">
                           <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.PanelBase}"/>
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.BorderStrong}"/>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.PanelElevated}"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.Border}"/>
                               <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style TargetType="TextBox">
           <Setter Property="Padding" Value="10,7"/>
           <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
           <Setter Property="BorderThickness" Value="1.5"/>
           <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="TextBox">
                       <Border x:Name="Root"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="10">
                           <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsKeyboardFocused" Value="True">
                               <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.FocusRing}"/>
                               <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.DisabledBg}"/>
                               <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style x:Key="LogReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
           <Setter Property="Background" Value="{StaticResource Color.LogAreaBg}"/>
           <Setter Property="BorderBrush" Value="{StaticResource Color.LogAreaBorder}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
           <Setter Property="Padding" Value="8,6"/>
       </Style>

       <Style TargetType="ComboBox">
           <Setter Property="Padding" Value="10,7"/>
           <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
           <Setter Property="BorderThickness" Value="1.5"/>
           <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
       </Style>

       <Style TargetType="ListBox">
           <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
       </Style>

       <Style TargetType="TabControl">
           <Setter Property="Background" Value="{StaticResource Color.TabBg}"/>
           <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="TabControl">
                       <Grid ClipToBounds="True">
                           <Grid.RowDefinitions>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="*"/>
                           </Grid.RowDefinitions>
                           <Border Grid.Row="0"
                                   Background="{TemplateBinding Background}"
                                   BorderBrush="{TemplateBinding BorderBrush}"
                                   BorderThickness="{TemplateBinding BorderThickness}"
                                   CornerRadius="8,8,0,0"
                                   Padding="2,2,2,0">
                               <TabPanel IsItemsHost="True" Background="Transparent"/>
                           </Border>
                           <Border Grid.Row="1"
                                   Background="{DynamicResource Color.PanelElevated}"
                                   BorderBrush="{TemplateBinding BorderBrush}"
                                   BorderThickness="{TemplateBinding BorderThickness}"
                                   CornerRadius="0,0,8,8"
                                   Padding="8">
                               <ContentPresenter ContentSource="SelectedContent"/>
                           </Border>
                       </Grid>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <Style TargetType="TabItem">
           <Setter Property="Background" Value="{StaticResource Color.TabBg}"/>
           <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
           <Setter Property="Foreground" Value="{StaticResource Color.TextMuted}"/>
           <Setter Property="Padding" Value="10,4"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="TabItem">
                       <Border x:Name="TabBorder"
                               Margin="0,0,4,0"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="6,6,0,0"
                               Padding="{TemplateBinding Padding}">
                           <ContentPresenter ContentSource="Header"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Color.BorderStrong}"/>
                           </Trigger>
                           <Trigger Property="IsSelected" Value="True">
                               <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Color.TabActive}"/>
                               <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Color.Primary}"/>
                               <Setter Property="Foreground" Value="{DynamicResource Color.Primary}"/>
                               <Setter Property="FontWeight" Value="SemiBold"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
           <Style.Triggers>
               <Trigger Property="IsSelected" Value="True">
                   <Setter Property="Background" Value="{StaticResource Color.TabActive}"/>
                   <Setter Property="BorderBrush" Value="{StaticResource Color.Primary}"/>
               </Trigger>
           </Style.Triggers>
       </Style>

       <Style TargetType="CheckBox">
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
           <Setter Property="Margin" Value="0,2,0,2"/>
       </Style>

       <Style TargetType="TextBlock">
           <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
       </Style>

       <Style TargetType="ProgressBar">
           <Setter Property="Background" Value="{StaticResource Color.SurfaceAlt}"/>
           <Setter Property="Height" Value="6"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="ProgressBar">
                       <Border CornerRadius="3" Background="{TemplateBinding Background}">
                           <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left">
                               <Border.Background>
                                   <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                       <GradientStop Color="#5B21B6" Offset="0"/>
                                       <GradientStop Color="#7C3AED" Offset="1"/>
                                   </LinearGradientBrush>
                               </Border.Background>
                           </Border>
                       </Border>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>
   </Application.Resources>
</Application>
