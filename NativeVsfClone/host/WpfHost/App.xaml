<Application x:Class="WpfHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <FontFamily x:Key="Font.Body">Segoe UI Variable Text</FontFamily>
        <FontFamily x:Key="Font.Display">Segoe UI Variable Display</FontFamily>

        <SolidColorBrush x:Key="Color.Surface" Color="#F2F6FC"/>
        <SolidColorBrush x:Key="Color.SurfaceAlt" Color="#EAF1FA"/>
        <SolidColorBrush x:Key="Color.Card" Color="#F8FBFF"/>
        <SolidColorBrush x:Key="Color.CardStrong" Color="#FEFFFF"/>
        <SolidColorBrush x:Key="Color.Border" Color="#C7D7EB"/>
        <SolidColorBrush x:Key="Color.BorderStrong" Color="#AFC4DE"/>
        <SolidColorBrush x:Key="Color.Text" Color="#1A2736"/>
        <SolidColorBrush x:Key="Color.TextMuted" Color="#53687D"/>
        <SolidColorBrush x:Key="Color.TextSubtle" Color="#6D8297"/>
        <SolidColorBrush x:Key="Color.Primary" Color="#0B6FC2"/>
        <SolidColorBrush x:Key="Color.PrimaryHover" Color="#0A62AB"/>
        <SolidColorBrush x:Key="Color.PrimaryPressed" Color="#084F89"/>
        <SolidColorBrush x:Key="Color.PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Color.Success" Color="#1E8A54"/>
        <SolidColorBrush x:Key="Color.Warning" Color="#A56B1A"/>
        <SolidColorBrush x:Key="Color.Error" Color="#AD3B3B"/>
        <SolidColorBrush x:Key="Color.TabBg" Color="#F0F4FA"/>
        <SolidColorBrush x:Key="Color.TabActive" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Color.NavRailBg" Color="#E8F0FA"/>
        <SolidColorBrush x:Key="Color.NavItemBg" Color="#F4F9FF"/>
        <SolidColorBrush x:Key="Color.NavItemActiveBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Color.NavItemText" Color="#3A4E63"/>
        <SolidColorBrush x:Key="Color.NavItemActiveText" Color="#1C2530"/>
        <SolidColorBrush x:Key="Color.OnboardingBarBg" Color="#E4F1FF"/>
        <SolidColorBrush x:Key="Color.OnboardingBarBorder" Color="#B2D1F0"/>
        <SolidColorBrush x:Key="Color.OnboardingBarTitle" Color="#0F365B"/>
        <SolidColorBrush x:Key="Color.OnboardingBarBody" Color="#244B71"/>
        <SolidColorBrush x:Key="Color.BadgeNeutralBg" Color="#EFF3F9"/>
        <SolidColorBrush x:Key="Color.BadgeNeutralText" Color="#43586E"/>
        <SolidColorBrush x:Key="Color.RenderShellBg" Color="#182639"/>
        <SolidColorBrush x:Key="Color.RenderShellBorder" Color="#5A708B"/>
        <SolidColorBrush x:Key="Color.StatusBarBg" Color="#24384E"/>
        <SolidColorBrush x:Key="Color.StatusBarBorder" Color="#546E88"/>
        <SolidColorBrush x:Key="Color.StatusBarLabel" Color="#D7E5F3"/>
        <SolidColorBrush x:Key="Color.StatusBarValue" Color="#F4FAFF"/>
        <SolidColorBrush x:Key="Color.PanelInfoBg" Color="#EEF5FE"/>
        <SolidColorBrush x:Key="Color.PanelInfoBorder" Color="#D0E0F2"/>
        <SolidColorBrush x:Key="Color.PanelInfoText" Color="#2F4F6F"/>
        <SolidColorBrush x:Key="Color.PanelInfoAltBg" Color="#E8F0FA"/>
        <SolidColorBrush x:Key="Color.PanelInfoAltBorder" Color="#C4D5EA"/>
        <SolidColorBrush x:Key="Color.PanelInfoAltText" Color="#223A55"/>
        <SolidColorBrush x:Key="Color.PanelSuccessBg" Color="#EEF6EF"/>
        <SolidColorBrush x:Key="Color.PanelSuccessBorder" Color="#BFDCC2"/>
        <SolidColorBrush x:Key="Color.PanelSuccessTitle" Color="#1E5130"/>
        <SolidColorBrush x:Key="Color.PanelSuccessText" Color="#2C6A3F"/>
        <SolidColorBrush x:Key="Color.PanelWarningBg" Color="#FFF8EE"/>
        <SolidColorBrush x:Key="Color.PanelWarningBorder" Color="#F3D2A7"/>
        <SolidColorBrush x:Key="Color.PanelWarningText" Color="#7C4012"/>
        <SolidColorBrush x:Key="Color.PanelErrorBg" Color="#FFF6F6"/>
        <SolidColorBrush x:Key="Color.PanelErrorBorder" Color="#F0B7B7"/>
        <SolidColorBrush x:Key="Color.PanelErrorText" Color="#7F1D1D"/>
        <SolidColorBrush x:Key="Color.ValidationErrorText" Color="#B03030"/>
        <SolidColorBrush x:Key="Color.CardSoftBg" Color="#F5F9FE"/>
        <SolidColorBrush x:Key="Color.CardSoftBorder" Color="#D7E0EA"/>
        <SolidColorBrush x:Key="Color.CardSoftBorderStrong" Color="#CCD8E6"/>
        <SolidColorBrush x:Key="Color.Splitter" Color="#B9C8DB"/>
        <SolidColorBrush x:Key="Color.OverlayHintBg" Color="#D0101720"/>
        <SolidColorBrush x:Key="Color.OverlayHintBorder" Color="#5A7088"/>
        <SolidColorBrush x:Key="Color.OverlayHintText" Color="#E8F0F8"/>
        <SolidColorBrush x:Key="Color.DebugOverlayBg" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="Color.DebugOverlayBorder" Color="#47627E"/>
        <SolidColorBrush x:Key="Color.DebugOverlayText" Color="#1A2530"/>
        <SolidColorBrush x:Key="Color.StepComplete" Color="#227842"/>
        <SolidColorBrush x:Key="Color.StepPending" Color="#35516B"/>
        <SolidColorBrush x:Key="Color.PanelBase" Color="#F3F7FD"/>
        <SolidColorBrush x:Key="Color.PanelElevated" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Color.PanelInset" Color="#EDF3FA"/>
        <SolidColorBrush x:Key="Color.FocusRing" Color="#4698E5"/>
        <SolidColorBrush x:Key="Color.DisabledBg" Color="#E5ECF5"/>
        <SolidColorBrush x:Key="Color.DisabledText" Color="#8A9AAF"/>
        <SolidColorBrush x:Key="Color.LogAreaBg" Color="#F4F7FC"/>
        <SolidColorBrush x:Key="Color.LogAreaBorder" Color="#C7D4E5"/>

        <Thickness x:Key="Spacing.ControlPadding">10,6</Thickness>
        <Thickness x:Key="Spacing.InputPadding">8,5</Thickness>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource Color.Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Color.Primary}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Primary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{StaticResource Spacing.ControlPadding}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinHeight" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.PrimaryHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.PrimaryHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.PrimaryPressed}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.PrimaryPressed}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Color.FocusRing}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource Color.DisabledBg}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
                    <Setter Property="Foreground" Value="{StaticResource Color.DisabledText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.SurfaceAlt}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.Surface}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TertiaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.SurfaceAlt}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.Surface}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Color.PanelInset}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.PanelBase}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.PanelElevated}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="{StaticResource Spacing.InputPadding}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Color.FocusRing}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="{StaticResource Color.LogAreaBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.LogAreaBorder}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Color.CardStrong}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource Color.TabBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8,8,0,0"
                                    Padding="2,2,2,0">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource Color.PanelElevated}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0,0,8,8"
                                    Padding="8">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource Color.TabBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color.Border}"/>
            <Setter Property="Foreground" Value="{StaticResource Color.TextMuted}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,4,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Color.BorderStrong}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Color.TabActive}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Color.BorderStrong}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Color.Text}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Color.DisabledText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Color.TabActive}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Color.BorderStrong}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Color.Text}"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource Color.Primary}"/>
            <Setter Property="Background" Value="{StaticResource Color.SurfaceAlt}"/>
            <Setter Property="Height" Value="10"/>
        </Style>
    </Application.Resources>
</Application>
