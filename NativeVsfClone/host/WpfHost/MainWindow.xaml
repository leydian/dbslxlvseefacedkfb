<Window x:Class="WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfHost"
        Title="VsfClone Host (WPF)" Height="840" Width="1420" MinHeight="760" MinWidth="1240">
    <Window.Resources>
        <Style x:Key="NavRailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Color.NavItemBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Color.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource Color.NavItemText}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="MinWidth" Value="124"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Color.Primary}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.95"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ControlsColumn" Width="560" />
            <ColumnDefinition x:Name="SplitterColumn" Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="156"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftRailPanel"
                    Grid.Column="0"
                    Background="{DynamicResource Color.NavRailBg}"
                    BorderBrush="{DynamicResource Color.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="WORKSPACE" Foreground="{DynamicResource Color.TextSubtle}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="Host Control" Margin="0,4,0,12" FontSize="18" FontWeight="SemiBold"/>
                    <Button x:Name="NavGettingStartedButton" Style="{StaticResource NavRailButtonStyle}" Content="Getting Started" Click="NavGettingStarted_Click" ToolTip="Ctrl+1"/>
                    <Button x:Name="NavSessionAvatarButton" Style="{StaticResource NavRailButtonStyle}" Content="Session / Avatar" Click="NavSessionAvatar_Click" ToolTip="Ctrl+2"/>
                    <Button x:Name="NavRenderButton" Style="{StaticResource NavRailButtonStyle}" Content="Render" Click="NavRender_Click" ToolTip="Ctrl+3"/>
                    <Button x:Name="NavOutputsButton" Style="{StaticResource NavRailButtonStyle}" Content="Outputs" Click="NavOutputs_Click" ToolTip="Ctrl+4"/>
                    <Button x:Name="NavTrackingButton" Style="{StaticResource NavRailButtonStyle}" Content="Tracking" Click="NavTracking_Click" ToolTip="Ctrl+5"/>
                    <Button x:Name="NavOpsButton" Style="{StaticResource NavRailButtonStyle}" Content="Platform Ops" Click="NavPlatformOps_Click" ToolTip="Ctrl+6"/>
                    <Separator Margin="0,4,0,8"/>
                    <Button x:Name="ToggleDiagnosticsButton" Style="{StaticResource NavRailButtonStyle}" Content="Diagnostics Panel" Click="ToggleDiagnosticsPanel_Click" ToolTip="Ctrl+D"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource Color.BorderStrong}" CornerRadius="3"/>

            <ScrollViewer x:Name="ControlPanelScrollViewer" Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,2">
                <GroupBox x:Name="ModeGroup" Header="모드 선택 (Mode)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="초급 모드는 필수 작업만 보여주고, 고급 모드는 전체 운영/진단 기능을 표시합니다." TextWrapping="Wrap" Foreground="#5E6B78" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Button x:Name="BeginnerModeButton" Content="초급 모드 (Beginner)" Click="BeginnerMode_Click" Margin="0,0,8,0" MinWidth="170"/>
                            <Button x:Name="AdvancedModeButton" Content="고급 모드 (Advanced)" Click="AdvancedMode_Click" MinWidth="170"/>
                            <Button x:Name="RenderOnlyToggleButton" Content="렌더 전용 모드 (F11)" Click="RenderOnlyToggle_Click" Margin="8,0,0,0" MinWidth="170"/>
                            <Button x:Name="ThemeToggleButton" Content="Dark Theme" Click="ThemeToggle_Click" Margin="8,0,0,0" MinWidth="120" ToolTip="Ctrl+T"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="QuickActionsGroup" Header="시작하기 (Getting Started)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="처음 실행 흐름: 세션 시작 -> 아바타 불러오기 -> 방송 출력 시작" TextWrapping="Wrap" Foreground="#5E6B78" Margin="0,0,0,8"/>
                        <Border Background="#F4F8FF" BorderBrush="#D0DDF4" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock x:Name="QuickNextActionText" Text="Step 1. Start Session" FontSize="16" FontWeight="SemiBold" Foreground="#17324D"/>
                                <TextBlock x:Name="PrimaryActionDescriptionText" Text="Initialize to prepare rendering and output pipeline." Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#2B4865"/>
                                <Button x:Name="PrimaryActionButton" Content="세션 시작" Click="PrimaryAction_Click" Margin="0,10,0,0" MinHeight="40" FontWeight="SemiBold"/>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="QuickInitializeButton" Content="1) 세션 시작" Click="QuickInitialize_Click" Margin="0,0,8,0" MinWidth="130"/>
                                    <Button x:Name="QuickLoadAvatarButton" Content="2) 아바타 로드" Click="QuickLoadAvatar_Click" Margin="0,0,8,0" MinWidth="130"/>
                                    <Button x:Name="QuickStartBroadcastButton" Content="3) 출력 시작" Click="QuickStartBroadcast_Click" MinWidth="130"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Border Background="#EEF4FD" BorderBrush="#D6E2F4" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="1) 세션 시작" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="OnboardingStep1Text" Text="대기" Margin="0,2,0,0" Foreground="#35516B"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#EEF4FD" BorderBrush="#D6E2F4" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="2) 아바타 불러오기" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="OnboardingStep2Text" Text="대기" Margin="0,2,0,0" Foreground="#35516B"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#EEF4FD" BorderBrush="#D6E2F4" BorderThickness="1" CornerRadius="4" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="3) 출력 시작" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="OnboardingStep3Text" Text="대기" Margin="0,2,0,0" Foreground="#35516B"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <Border Background="#EDF3FA" BorderBrush="#CAD8E8" BorderThickness="1" CornerRadius="4" Padding="8,6">
                            <TextBlock x:Name="QuickStatusText" Text="Session=Stopped | Avatar=None | Outputs=Off" TextWrapping="Wrap" Foreground="#243548" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#EEF6EF" BorderBrush="#BFDCC2" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="첫 방송 시작 시간" FontWeight="SemiBold" Foreground="#1E5130"/>
                                <TextBlock x:Name="FirstBroadcastTimingText" Text="최근: 측정 대기" Margin="0,2,0,0" Foreground="#2C6A3F"/>
                                <TextBlock x:Name="FlowMedianTimingText" Text="중앙값(최근 20회): 측정 대기" Margin="0,2,0,0" Foreground="#2C6A3F"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ActionBlockReasonPanel" Background="#FFF8EE" BorderBrush="#F3D2A7" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="현재 차단 사유" FontWeight="SemiBold" Foreground="#7C4012"/>
                                <TextBlock x:Name="ActionBlockReasonText" Text="없음" TextWrapping="Wrap" Foreground="#7C4012" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BeginnerFailureHintPanel" Visibility="Collapsed" Background="#FFF6F6" BorderBrush="#F0B7B7" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Action needed" FontWeight="SemiBold" Foreground="#7F1D1D" Margin="0,0,0,2"/>
                                <TextBlock x:Name="BeginnerFailureHintText" TextWrapping="Wrap" Foreground="#7F1D1D"/>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="OpenDiagnosticsFromHintButton" Content="Open Advanced Diagnostics" Click="OpenDiagnosticsFromHint_Click" HorizontalAlignment="Left" MinWidth="180"/>
                                    <Button x:Name="DismissFailureHintButton" Content="Dismiss" Click="DismissFailureHint_Click" Margin="8,0,0,0" HorizontalAlignment="Left" MinWidth="90"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border x:Name="OnboardingRecoveryPanel" Visibility="Collapsed" Background="#FFF8EE" BorderBrush="#F3D2A7" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="복구 안내 (Recovery)" FontWeight="SemiBold" Foreground="#7C4012"/>
                                <TextBlock x:Name="OnboardingRecoveryText" TextWrapping="Wrap" Foreground="#7C4012" Margin="0,2,0,0"/>
                                <Button x:Name="DismissRecoveryHintButton" Content="Dismiss" Click="DismissFailureHint_Click" Margin="0,8,0,0" HorizontalAlignment="Left" MinWidth="90"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="SessionGroup" Header="1) 세션 (Session)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="세션 시작/종료를 제어합니다." TextWrapping="Wrap" Foreground="#5E6B78" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Button x:Name="InitializeButton" Content="초기화 (Initialize)" Click="Initialize_Click" Margin="0,0,8,0" MinWidth="130"/>
                            <Button x:Name="ShutdownButton" Content="종료 (Shutdown)" Click="Shutdown_Click" MinWidth="130"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="AvatarGroup" Header="2) 아바타 (Avatar)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="아바타 파일 경로 (Avatar Path)" FontWeight="SemiBold"/>
                        <DockPanel Margin="0,4,0,8">
                            <Button x:Name="BrowseAvatarButton" Content="찾아보기..." Click="BrowseAvatar_Click" Width="84" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                            <TextBox x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm" TextChanged="InputTextChanged" />
                        </DockPanel>
                        <TextBlock x:Name="AvatarPathValidationText" Foreground="#B03030" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Border BorderBrush="#D7E0EA" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="132"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="120" Height="120" BorderBrush="#CCD8E6" BorderThickness="1" Background="#F5F9FE" CornerRadius="4" VerticalAlignment="Top">
                                    <Image x:Name="AvatarPreviewImage" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="현재 선택 미리보기" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AvatarPreviewStatusText" Text="선택된 파일 없음" Margin="0,4,0,8" TextWrapping="Wrap" Foreground="#5E6B78"/>
                                    <Button x:Name="RetryAvatarPreviewButton" Content="미리보기 재생성" Click="RetryAvatarPreview_Click" MinWidth="120" HorizontalAlignment="Left"/>
                                    <TextBlock Text="최근 사용 아바타" FontWeight="SemiBold" Margin="0,10,0,4"/>
                                    <ListBox x:Name="RecentAvatarListBox" Height="100" SelectionChanged="RecentAvatarList_SelectionChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <WrapPanel>
                            <Button x:Name="LoadButton" Content="불러오기 (Load)" Click="Load_Click" Margin="0,0,8,0" MinWidth="130"/>
                            <Button x:Name="CancelLoadButton" Content="불러오기 취소" Click="CancelLoad_Click" Margin="0,0,8,0" MinWidth="130"/>
                            <Button x:Name="UnloadButton" Content="해제 (Unload)" Click="Unload_Click" MinWidth="130"/>
                        </WrapPanel>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="LoadTimeoutTextBox" Text="20000"/>
                            <TextBlock Grid.Column="2" Text="ms" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ProgressBar x:Name="LoadProgressBar" Margin="0,8,0,4" Minimum="0" Maximum="100" Height="10" Value="0"/>
                        <TextBlock x:Name="LoadProgressText" Text="Load progress: idle" Foreground="#5E6B78" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="RenderGroup" Header="3) 렌더 (Render)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <Border BorderBrush="#D7E0EA" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="기본 (Basic)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <CheckBox x:Name="BroadcastModeCheckBox" Content="방송 모드 (Broadcast Mode)" Checked="BroadcastMode_Changed" Unchecked="BroadcastMode_Changed" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Camera" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="CameraModeComboBox" SelectionChanged="CameraMode_SelectionChanged">
                                        <ComboBoxItem Content="Auto Fit Full"/>
                                        <ComboBoxItem Content="Auto Fit Bust"/>
                                        <ComboBoxItem Content="Manual"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Framing" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="FramingSlider" Minimum="0.35" Maximum="0.95" Value="0.72" TickFrequency="0.01" IsSnapToTickEnabled="False" ValueChanged="FramingSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="FramingValueText" Text="0.72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Expander x:Name="RenderAdvancedExpander" Header="고급 설정 (Advanced)" IsExpanded="False">
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Headroom" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="HeadroomSlider" Minimum="0.00" Maximum="0.50" Value="0.10" TickFrequency="0.01" IsSnapToTickEnabled="False" ValueChanged="HeadroomSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="HeadroomValueText" Text="0.10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Yaw" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="YawSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="YawSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="YawValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="FovSlider" Minimum="20" Maximum="70" Value="35" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="FovSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="FovValueText" Text="35" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Background" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="BackgroundPresetComboBox" SelectionChanged="BackgroundPreset_SelectionChanged">
                                        <ComboBoxItem Content="Dark Blue"/>
                                        <ComboBoxItem Content="Neutral Gray"/>
                                        <ComboBoxItem Content="Green Screen"/>
                                    </ComboBox>
                                </Grid>
                                <CheckBox x:Name="MirrorModeCheckBox" Content="미러 모드 (Mirror Mode)" Checked="MirrorMode_Changed" Unchecked="MirrorMode_Changed" Margin="0,0,0,8"/>
                                <CheckBox x:Name="DebugOverlayCheckBox" Content="디버그 오버레이 표시" Checked="DebugOverlay_Changed" Unchecked="DebugOverlay_Changed"/>
                                <Separator Margin="0,10,0,10"/>
                                <TextBlock Text="Pose (본 포즈 보정)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bone" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="PoseBoneComboBox" SelectionChanged="PoseBone_SelectionChanged">
                                        <ComboBoxItem Content="Hips"/>
                                        <ComboBoxItem Content="Spine"/>
                                        <ComboBoxItem Content="Chest"/>
                                        <ComboBoxItem Content="UpperChest"/>
                                        <ComboBoxItem Content="Neck"/>
                                        <ComboBoxItem Content="Head"/>
                                        <ComboBoxItem Content="LeftUpperArm"/>
                                        <ComboBoxItem Content="RightUpperArm"/>
                                        <ComboBoxItem Content="LeftShoulder"/>
                                        <ComboBoxItem Content="RightShoulder"/>
                                        <ComboBoxItem Content="LeftLowerArm"/>
                                        <ComboBoxItem Content="RightLowerArm"/>
                                        <ComboBoxItem Content="LeftHand"/>
                                        <ComboBoxItem Content="RightHand"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pitch" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="PosePitchSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="PoseSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="PosePitchValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Yaw" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="PoseYawSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="PoseSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="PoseYawValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Roll" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="PoseRollSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="PoseSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="PoseRollValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="Arm Pitch (팔 올림/내림)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Both" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="ArmBothPitchSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="ArmPoseSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="ArmBothPitchValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Left Arm" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="ArmLeftPitchSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="ArmPoseSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="ArmLeftPitchValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Right Arm" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="ArmRightPitchSlider" Minimum="-180" Maximum="180" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="ArmPoseSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="ArmRightPitchValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <WrapPanel Margin="0,0,0,8">
                                    <Button x:Name="PoseResetBoneButton" Content="Reset Bone" Width="100" Margin="0,0,8,0" Click="PoseResetBone_Click"/>
                                    <Button x:Name="PoseResetAllButton" Content="Reset All" Width="100" Click="PoseResetAll_Click"/>
                                </WrapPanel>
                                <TextBlock Text="Pose Presets" FontWeight="SemiBold"/>
                                <DockPanel Margin="0,4,0,8">
                                    <Button x:Name="SavePosePresetButton" Content="Save Pose" Width="88" Click="SavePosePreset_Click" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                    <TextBox x:Name="PosePresetNameTextBox" Text="My Pose Preset"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <WrapPanel DockPanel.Dock="Right">
                                        <Button x:Name="ApplyPosePresetButton" Content="적용" Width="74" Margin="8,0,0,0" Click="ApplyPosePreset_Click"/>
                                        <Button x:Name="DeletePosePresetButton" Content="삭제" Width="74" Margin="8,0,0,0" Click="DeletePosePreset_Click"/>
                                    </WrapPanel>
                                    <ComboBox x:Name="PosePresetComboBox"/>
                                </DockPanel>
                                <TextBlock Text="Arm Quality" FontWeight="SemiBold"/>
                                <WrapPanel Margin="0,4,0,8">
                                    <CheckBox x:Name="ArmSmoothingCheckBox" Content="Smoothing" IsChecked="True" Checked="ArmTuning_Changed" Unchecked="ArmTuning_Changed" Margin="0,0,12,0"/>
                                    <TextBlock Text="Deadband" VerticalAlignment="Center"/>
                                    <Slider x:Name="ArmDeadbandSlider" Width="120" Minimum="0.0" Maximum="3.0" Value="0.8" TickFrequency="0.1" ValueChanged="ArmTuning_Changed" Margin="8,0,0,0"/>
                                    <TextBlock x:Name="ArmDeadbandValueText" Text="0.80°" Width="52" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </WrapPanel>
                                <TextBlock Text="Suggested Arm Presets" FontWeight="SemiBold"/>
                                <DockPanel Margin="0,4,0,8">
                                    <WrapPanel DockPanel.Dock="Right">
                                        <Button x:Name="ApplySuggestedArmPresetButton" Content="적용" Width="74" Margin="8,0,0,0" Click="ApplySuggestedArmPreset_Click"/>
                                        <Button x:Name="SaveSuggestedArmPresetButton" Content="저장" Width="74" Margin="8,0,0,0" Click="SaveSuggestedArmPreset_Click"/>
                                    </WrapPanel>
                                    <ComboBox x:Name="SuggestedArmPresetComboBox"/>
                                </DockPanel>
                                <Separator Margin="0,10,0,10"/>
                                <TextBlock Text="프리셋 (Presets)" FontWeight="SemiBold"/>
                                <DockPanel Margin="0,4,0,8">
                                    <Button x:Name="SavePresetButton" Content="Save" Width="74" Click="SavePreset_Click" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                    <TextBox x:Name="PresetNameTextBox" Text="My Preset"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <WrapPanel DockPanel.Dock="Right">
                                        <Button x:Name="ApplyPresetButton" Content="적용" Width="74" Margin="8,0,0,0" Click="ApplyPreset_Click"/>
                                        <Button x:Name="DeletePresetButton" Content="삭제" Width="74" Margin="8,0,0,0" Click="DeletePreset_Click"/>
                                    </WrapPanel>
                                    <ComboBox x:Name="PresetComboBox"/>
                                </DockPanel>
                                <Button x:Name="ResetRenderButton" Content="Reset To Default" Width="132" Click="ResetRender_Click"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="OutputsGroup" Header="4) 출력 (Outputs)">
                    <StackPanel Margin="8">
                        <TextBlock Text="Spout" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Channel" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="SpoutChannelTextBox" Text="VsfClone"/>
                        </Grid>
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="StartSpoutButton" Content="Spout 시작" Click="StartSpout_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="StopSpoutButton" Content="Spout 중지" Click="StopSpout_Click" MinWidth="110"/>
                        </WrapPanel>

                        <TextBlock Text="OSC" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind Port" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="OscBindPortTextBox" Text="39539" TextChanged="InputTextChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Publish" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="OscPublishAddressTextBox" Text="127.0.0.1:39540" Margin="0,8,0,0" TextChanged="InputTextChanged"/>
                        </Grid>
                        <TextBlock x:Name="OscBindValidationText" Foreground="#B03030" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBlock x:Name="OscPublishValidationText" Foreground="#B03030" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <WrapPanel>
                            <Button x:Name="StartOscButton" Content="OSC 시작" Click="StartOsc_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="StopOscButton" Content="OSC 중지" Click="StopOsc_Click" MinWidth="110"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="TrackingGroup" Header="5) 트래킹 입력 (Tracking Input)" Margin="0,8,0,0">
                    <StackPanel Margin="8">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Listen Port" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TrackingPortTextBox" Text="49983"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Source" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TrackingSourceComboBox" Margin="0,8,0,0">
                                <ComboBoxItem Content="Auto (OSC + Webcam)"/>
                                <ComboBoxItem Content="OSC (iFacialMocap)"/>
                                <ComboBoxItem Content="Webcam (MediaPipe)"/>
                            </ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Webcam" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
                                <Button x:Name="RefreshTrackingWebcamButton" Content="새로고침" Width="70" DockPanel.Dock="Right" Margin="8,0,0,0" Click="RefreshTrackingWebcam_Click"/>
                                <ComboBox x:Name="TrackingWebcamDeviceComboBox"/>
                            </DockPanel>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Infer FPS" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TrackingInferenceFpsTextBox" Text="30" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Parse Warn" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="TrackingParseWarnThresholdTextBox" Text="10" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Drop Warn" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="TrackingDropWarnThresholdTextBox" Text="10" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Source Lock" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="6" Grid.Column="1" x:Name="TrackingSourceLockComboBox" Margin="0,8,0,0">
                                <ComboBoxItem Content="Auto"/>
                                <ComboBoxItem Content="iFacial Locked"/>
                                <ComboBoxItem Content="Webcam Locked"/>
                            </ComboBox>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Latency" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="7" Grid.Column="1" x:Name="TrackingLatencyProfileComboBox" Margin="0,8,0,0">
                                <ComboBoxItem Content="Low Latency"/>
                                <ComboBoxItem Content="Balanced"/>
                                <ComboBoxItem Content="Stable"/>
                            </ComboBox>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Pose Filter" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="8" Grid.Column="1" x:Name="TrackingPoseFilterProfileComboBox" Margin="0,8,0,0" SelectionChanged="TrackingPoseFilterProfile_SelectionChanged">
                                <ComboBoxItem Content="Reactive"/>
                                <ComboBoxItem Content="Balanced"/>
                                <ComboBoxItem Content="Stable"/>
                            </ComboBox>
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Deadband" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <DockPanel Grid.Row="9" Grid.Column="1" Margin="0,8,0,0">
                                <TextBlock x:Name="TrackingPoseDeadbandValueText" Text="0.90°" Width="56" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                <Slider x:Name="TrackingPoseDeadbandSlider" Minimum="0.0" Maximum="3.0" Value="0.9" TickFrequency="0.05" IsSnapToTickEnabled="False" ValueChanged="TrackingPoseDeadbandSlider_ValueChanged"/>
                            </DockPanel>
                        </Grid>
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="StartTrackingButton" Content="Start Tracking" Click="StartTracking_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="StopTrackingButton" Content="Stop Tracking" Click="StopTracking_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="RecenterTrackingButton" Content="Recenter" Click="RecenterTracking_Click" MinWidth="96"/>
                        </WrapPanel>
                        <TextBlock x:Name="TrackingStatusText" Foreground="#5E6B78" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="PlatformOpsGroup" Header="6) 운영/진단 (Platform Ops)" Margin="0,8,0,0">
                    <StackPanel Margin="8">
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="RunPreflightButton" Content="사전 점검 실행" Click="RunPreflight_Click" Margin="0,0,8,0" MinWidth="112"/>
                            <Button x:Name="ExportDiagButton" Content="진단 내보내기" Click="ExportDiag_Click" Margin="0,0,8,0" MinWidth="128"/>
                            <Button x:Name="ExportMetricsButton" Content="메트릭 내보내기" Click="ExportMetrics_Click" MinWidth="112"/>
                        </WrapPanel>
                        <TextBlock x:Name="PreflightHintText" Foreground="#5E6B78" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="렌더 프로파일 (Render Profiles)" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,4,0,8">
                            <Button Content="Quality" Click="ProfileQuality_Click" Margin="0,0,8,0" MinWidth="92"/>
                            <Button Content="Performance" Click="ProfilePerformance_Click" Margin="0,0,8,0" MinWidth="92"/>
                            <Button Content="Stability" Click="ProfileStability_Click" MinWidth="92"/>
                        </WrapPanel>

                        <TextBlock Text="Sidecar 설정" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ParserModeComboBox">
                                <ComboBoxItem Content="sidecar"/>
                                <ComboBoxItem Content="inhouse"/>
                                <ComboBoxItem Content="sidecar-strict"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="SidecarPathTextBox" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Timeout" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="SidecarTimeoutTextBox" Text="15000" Margin="0,8,0,0"/>
                        </Grid>
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox x:Name="SidecarStrictCheckBox" Content="엄격 모드 (Strict, no fallback)" Margin="0,0,12,0"/>
                            <Button Content="Sidecar 적용" Click="ApplySidecar_Click" MinWidth="112"/>
                        </WrapPanel>

                        <TextBlock Text="텔레메트리 (Telemetry)" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox x:Name="TelemetryOptInCheckBox" Content="수집 동의 (Opt-in)" Margin="0,0,8,0"/>
                            <CheckBox x:Name="TelemetryRedactCheckBox" Content="Redact Sensitive" IsChecked="True" Margin="0,0,8,0"/>
                            <Button Content="Telemetry 적용" Click="ApplyTelemetry_Click" Margin="0,0,8,0" MinWidth="112"/>
                            <Button Content="Telemetry 내보내기" Click="ExportTelemetry_Click" MinWidth="120"/>
                        </WrapPanel>

                        <TextBlock Text="자동 품질 정책 (Auto Quality)" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Threshold"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="AutoQualityThresholdTextBox" Text="28.0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Consecutive" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="AutoQualityConsecutiveTextBox" Text="120" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cooldown" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="AutoQualityCooldownTextBox" Text="30" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Recovery ms" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="AutoQualityRecoveryThresholdTextBox" Text="22.0" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Recovery n" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="AutoQualityRecoveryConsecutiveTextBox" Text="240" Margin="0,8,0,0"/>
                        </Grid>
                        <Button Content="자동 품질 정책 적용" Click="ApplyAutoQualityPolicy_Click" MinWidth="170"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <GridSplitter x:Name="MainGridSplitter" Grid.Column="1" Width="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#B9C8DB" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition x:Name="DiagnosticsRow" Height="260" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border Background="{DynamicResource Color.RenderShellBg}" BorderBrush="{DynamicResource Color.RenderShellBorder}" BorderThickness="1" CornerRadius="8">
                    <local:RenderHwndHost x:Name="RenderHost"/>
                </Border>
                <Border x:Name="RenderOnlyHintOverlay"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="12,6"
                        Panel.ZIndex="20"
                        Background="#D0101720"
                        BorderBrush="#5A7088"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock Text="렌더 전용 모드 (Render-only) · F11로 UI 복귀"
                               Foreground="#E8F0F8"
                               FontWeight="SemiBold"/>
                </Border>
                <Border x:Name="DebugOverlayPanel" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Padding="8" Background="#EEFFFFFF" BorderBrush="#47627E" BorderThickness="1" CornerRadius="6">
                    <TextBlock x:Name="DebugOverlayText" FontFamily="Consolas" FontSize="11" Foreground="#1A2530" TextWrapping="Wrap" Width="420"/>
                </Border>
            </Grid>

            <TabControl x:Name="DiagnosticsTabControl" Grid.Row="1" Margin="0,8,0,8" SelectionChanged="DiagnosticsTabControl_SelectionChanged">
                <TabItem Header="런타임 (Runtime)">
                    <DockPanel>
                        <Button Content="런타임 복사" DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,8" Padding="10,4" Click="CopyRuntime_Click"/>
                        <TextBox x:Name="RuntimeDiagnosticsTextBox" IsReadOnly="True" IsReadOnlyCaretVisible="True" TextWrapping="NoWrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="아바타 (Avatar)">
                    <DockPanel>
                        <Button Content="아바타 복사" DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,8" Padding="10,4" Click="CopyAvatar_Click"/>
                        <TextBox x:Name="AvatarDiagnosticsTextBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="로그 (Logs)">
                    <DockPanel>
                        <Button Content="로그 복사" DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,8" Padding="10,4" Click="CopyLogs_Click"/>
                        <TextBox x:Name="LogsTextBox" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="가이드 (Guides)">
                    <TextBox x:Name="GuidesTextBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                </TabItem>
            </TabControl>

            <Border x:Name="StatusBarBorder" Grid.Row="2" Padding="8" Background="{DynamicResource Color.StatusBarBg}" BorderBrush="{DynamicResource Color.StatusBarBorder}" BorderThickness="1" CornerRadius="8">
                <WrapPanel>
                    <TextBlock Text="Session: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="SessionStatusText" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="Avatar: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="AvatarStatusText" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="Render: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="RenderStatusText" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="Frame: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="FrameStatusText" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="Outputs: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="OutputStatusText" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="Busy: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="BusyStatusText" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="LastError: " Foreground="{DynamicResource Color.StatusBarLabel}"/>
                    <TextBlock x:Name="ErrorStatusText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Width="360" Foreground="{DynamicResource Color.StatusBarValue}"/>
                    <TextBlock Text="Track: " Foreground="{DynamicResource Color.StatusBarLabel}" Margin="12,0,0,0"/>
                    <TextBlock x:Name="TrackStatusText" FontWeight="SemiBold" Width="300" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Color.StatusBarValue}"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</Window>




