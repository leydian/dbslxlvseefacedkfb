<Window x:Class="WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfHost"
        Title="VsfClone Host (WPF)" Height="840" Width="1420" MinHeight="760" MinWidth="1240">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="440" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox x:Name="ModeGroup" Header="모드 선택 (Mode)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="초급 모드는 필수 작업만 보여주고, 고급 모드는 전체 운영/진단 기능을 표시합니다." TextWrapping="Wrap" Foreground="#5E6B78" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Button x:Name="BeginnerModeButton" Content="초급 모드 (Beginner)" Click="BeginnerMode_Click" Margin="0,0,8,0" MinWidth="170"/>
                            <Button x:Name="AdvancedModeButton" Content="고급 모드 (Advanced)" Click="AdvancedMode_Click" MinWidth="170"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="QuickActionsGroup" Header="Quick Start" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="Recommended flow: 1) Initialize, 2) Load avatar, 3) Start output." TextWrapping="Wrap" Foreground="#5E6B78" Margin="0,0,0,6"/>
                        <Border Background="#F8FBFF" BorderBrush="#D5E4F5" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <TextBlock x:Name="QuickNextActionText" Text="Step 1: Click Initialize to start the session." TextWrapping="Wrap" Foreground="#19324B" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#EDF3FA" BorderBrush="#CAD8E8" BorderThickness="1" CornerRadius="4" Padding="8,6">
                            <TextBlock x:Name="QuickStatusText" Text="Session=Stopped | Avatar=None | Outputs=Off" TextWrapping="Wrap" Foreground="#243548" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="BeginnerFailureHintPanel" Visibility="Collapsed" Background="#FFF6F6" BorderBrush="#F0B7B7" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Action needed" FontWeight="SemiBold" Foreground="#7F1D1D" Margin="0,0,0,2"/>
                                <TextBlock x:Name="BeginnerFailureHintText" TextWrapping="Wrap" Foreground="#7F1D1D"/>
                                <Button x:Name="OpenDiagnosticsFromHintButton" Content="Open Advanced Diagnostics" Click="OpenDiagnosticsFromHint_Click" Margin="0,8,0,0" HorizontalAlignment="Left" MinWidth="180"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="SessionGroup" Header="1) 세션 (Session)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="세션 시작/종료를 제어합니다." TextWrapping="Wrap" Foreground="#5E6B78" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <Button x:Name="InitializeButton" Content="초기화 (Initialize)" Click="Initialize_Click" Margin="0,0,8,0" MinWidth="130"/>
                            <Button x:Name="ShutdownButton" Content="종료 (Shutdown)" Click="Shutdown_Click" MinWidth="130"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="AvatarGroup" Header="2) 아바타 (Avatar)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="아바타 파일 경로 (Avatar Path)" FontWeight="SemiBold"/>
                        <DockPanel Margin="0,4,0,8">
                            <Button x:Name="BrowseAvatarButton" Content="찾아보기..." Click="BrowseAvatar_Click" Width="84" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                            <TextBox x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm" TextChanged="InputTextChanged" />
                        </DockPanel>
                        <TextBlock x:Name="AvatarPathValidationText" Foreground="#B03030" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <WrapPanel>
                            <Button x:Name="LoadButton" Content="불러오기 (Load)" Click="Load_Click" Margin="0,0,8,0" MinWidth="130"/>
                            <Button x:Name="CancelLoadButton" Content="불러오기 취소" Click="CancelLoad_Click" Margin="0,0,8,0" MinWidth="130"/>
                            <Button x:Name="UnloadButton" Content="해제 (Unload)" Click="Unload_Click" MinWidth="130"/>
                        </WrapPanel>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timeout" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="LoadTimeoutTextBox" Text="20000"/>
                            <TextBlock Grid.Column="2" Text="ms" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ProgressBar x:Name="LoadProgressBar" Margin="0,8,0,4" Minimum="0" Maximum="100" Height="10" Value="0"/>
                        <TextBlock x:Name="LoadProgressText" Text="Load progress: idle" Foreground="#5E6B78" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="RenderGroup" Header="3) 렌더 (Render)" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <Border BorderBrush="#D7E0EA" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="기본 (Basic)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <CheckBox x:Name="BroadcastModeCheckBox" Content="방송 모드 (Broadcast Mode)" Checked="BroadcastMode_Changed" Unchecked="BroadcastMode_Changed" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Camera" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="CameraModeComboBox" SelectionChanged="CameraMode_SelectionChanged">
                                        <ComboBoxItem Content="Auto Fit Full"/>
                                        <ComboBoxItem Content="Auto Fit Bust"/>
                                        <ComboBoxItem Content="Manual"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Framing" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="FramingSlider" Minimum="0.35" Maximum="0.95" Value="0.72" TickFrequency="0.01" IsSnapToTickEnabled="False" ValueChanged="FramingSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="FramingValueText" Text="0.72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Expander x:Name="RenderAdvancedExpander" Header="고급 설정 (Advanced)" IsExpanded="True">
                            <StackPanel Margin="0,8,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Headroom" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="HeadroomSlider" Minimum="0.00" Maximum="0.50" Value="0.10" TickFrequency="0.01" IsSnapToTickEnabled="False" ValueChanged="HeadroomSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="HeadroomValueText" Text="0.10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Yaw" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="YawSlider" Minimum="-45" Maximum="45" Value="0" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="YawSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="YawValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="FovSlider" Minimum="20" Maximum="70" Value="35" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="FovSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="FovValueText" Text="35" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Background" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="BackgroundPresetComboBox" SelectionChanged="BackgroundPreset_SelectionChanged">
                                        <ComboBoxItem Content="Dark Blue"/>
                                        <ComboBoxItem Content="Neutral Gray"/>
                                        <ComboBoxItem Content="Green Screen"/>
                                    </ComboBox>
                                </Grid>
                                <CheckBox x:Name="MirrorModeCheckBox" Content="미러 모드 (Mirror Mode)" Checked="MirrorMode_Changed" Unchecked="MirrorMode_Changed" Margin="0,0,0,8"/>
                                <CheckBox x:Name="DebugOverlayCheckBox" Content="디버그 오버레이 표시" Checked="DebugOverlay_Changed" Unchecked="DebugOverlay_Changed"/>
                                <Separator Margin="0,10,0,10"/>
                                <TextBlock Text="프리셋 (Presets)" FontWeight="SemiBold"/>
                                <DockPanel Margin="0,4,0,8">
                                    <Button x:Name="SavePresetButton" Content="Save" Width="74" Click="SavePreset_Click" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                    <TextBox x:Name="PresetNameTextBox" Text="My Preset"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <WrapPanel DockPanel.Dock="Right">
                                        <Button x:Name="ApplyPresetButton" Content="적용" Width="74" Margin="8,0,0,0" Click="ApplyPreset_Click"/>
                                        <Button x:Name="DeletePresetButton" Content="삭제" Width="74" Margin="8,0,0,0" Click="DeletePreset_Click"/>
                                    </WrapPanel>
                                    <ComboBox x:Name="PresetComboBox"/>
                                </DockPanel>
                                <Button x:Name="ResetRenderButton" Content="Reset To Default" Width="132" Click="ResetRender_Click"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="OutputsGroup" Header="4) 출력 (Outputs)">
                    <StackPanel Margin="8">
                        <TextBlock Text="Spout" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Channel" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="SpoutChannelTextBox" Text="VsfClone"/>
                        </Grid>
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="StartSpoutButton" Content="Spout 시작" Click="StartSpout_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="StopSpoutButton" Content="Spout 중지" Click="StopSpout_Click" MinWidth="110"/>
                        </WrapPanel>

                        <TextBlock Text="OSC" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind Port" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="OscBindPortTextBox" Text="39539" TextChanged="InputTextChanged"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Publish" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="OscPublishAddressTextBox" Text="127.0.0.1:39540" Margin="0,8,0,0" TextChanged="InputTextChanged"/>
                        </Grid>
                        <TextBlock x:Name="OscBindValidationText" Foreground="#B03030" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBlock x:Name="OscPublishValidationText" Foreground="#B03030" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <WrapPanel>
                            <Button x:Name="StartOscButton" Content="OSC 시작" Click="StartOsc_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="StopOscButton" Content="OSC 중지" Click="StopOsc_Click" MinWidth="110"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="TrackingGroup" Header="5) 트래킹 입력 (Tracking Input)" Margin="0,8,0,0">
                    <StackPanel Margin="8">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Listen Port" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TrackingPortTextBox" Text="49983"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Source" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TrackingSourceComboBox" Margin="0,8,0,0">
                                <ComboBoxItem Content="OSC (iFacialMocap)"/>
                                <ComboBoxItem Content="Webcam (ONNX)"/>
                            </ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Webcam Id" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TrackingWebcamDeviceTextBox" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ONNX Path" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TrackingOnnxModelPathTextBox" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Infer FPS" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="TrackingInferenceFpsTextBox" Text="30" Margin="0,8,0,0"/>
                        </Grid>
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="StartTrackingButton" Content="Start Tracking" Click="StartTracking_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="StopTrackingButton" Content="Stop Tracking" Click="StopTracking_Click" Margin="0,0,8,0" MinWidth="110"/>
                            <Button x:Name="RecenterTrackingButton" Content="Recenter" Click="RecenterTracking_Click" MinWidth="96"/>
                        </WrapPanel>
                        <TextBlock x:Name="TrackingStatusText" Foreground="#5E6B78" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="PlatformOpsGroup" Header="6) 운영/진단 (Platform Ops)" Margin="0,8,0,0">
                    <StackPanel Margin="8">
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="RunPreflightButton" Content="사전 점검 실행" Click="RunPreflight_Click" Margin="0,0,8,0" MinWidth="112"/>
                            <Button x:Name="ExportDiagButton" Content="진단 내보내기" Click="ExportDiag_Click" Margin="0,0,8,0" MinWidth="128"/>
                            <Button x:Name="ExportMetricsButton" Content="메트릭 내보내기" Click="ExportMetrics_Click" MinWidth="112"/>
                        </WrapPanel>
                        <TextBlock x:Name="PreflightHintText" Foreground="#5E6B78" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="렌더 프로파일 (Render Profiles)" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,4,0,8">
                            <Button Content="Quality" Click="ProfileQuality_Click" Margin="0,0,8,0" MinWidth="92"/>
                            <Button Content="Performance" Click="ProfilePerformance_Click" Margin="0,0,8,0" MinWidth="92"/>
                            <Button Content="Stability" Click="ProfileStability_Click" MinWidth="92"/>
                        </WrapPanel>

                        <TextBlock Text="Sidecar 설정" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ParserModeComboBox">
                                <ComboBoxItem Content="sidecar"/>
                                <ComboBoxItem Content="inhouse"/>
                                <ComboBoxItem Content="sidecar-strict"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="SidecarPathTextBox" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Timeout" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="SidecarTimeoutTextBox" Text="15000" Margin="0,8,0,0"/>
                        </Grid>
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox x:Name="SidecarStrictCheckBox" Content="엄격 모드 (Strict, no fallback)" Margin="0,0,12,0"/>
                            <Button Content="Sidecar 적용" Click="ApplySidecar_Click" MinWidth="112"/>
                        </WrapPanel>

                        <TextBlock Text="텔레메트리 (Telemetry)" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox x:Name="TelemetryOptInCheckBox" Content="수집 동의 (Opt-in)" Margin="0,0,8,0"/>
                            <CheckBox x:Name="TelemetryRedactCheckBox" Content="Redact Sensitive" IsChecked="True" Margin="0,0,8,0"/>
                            <Button Content="Telemetry 적용" Click="ApplyTelemetry_Click" Margin="0,0,8,0" MinWidth="112"/>
                            <Button Content="Telemetry 내보내기" Click="ExportTelemetry_Click" MinWidth="120"/>
                        </WrapPanel>

                        <TextBlock Text="자동 품질 정책 (Auto Quality)" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Threshold"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="AutoQualityThresholdTextBox" Text="28.0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Consecutive" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="AutoQualityConsecutiveTextBox" Text="120" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cooldown" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="AutoQualityCooldownTextBox" Text="30" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Recovery ms" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="AutoQualityRecoveryThresholdTextBox" Text="22.0" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Recovery n" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="AutoQualityRecoveryConsecutiveTextBox" Text="240" Margin="0,8,0,0"/>
                        </Grid>
                        <Button Content="자동 품질 정책 적용" Click="ApplyAutoQualityPolicy_Click" MinWidth="170"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#102030" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition x:Name="DiagnosticsRow" Height="260" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border Background="#111722" BorderBrush="#304050" BorderThickness="1" CornerRadius="4">
                    <local:RenderHwndHost x:Name="RenderHost"/>
                </Border>
                <Border x:Name="DebugOverlayPanel" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Padding="8" Background="#EEFFFFFF" BorderBrush="#203040" BorderThickness="1" CornerRadius="2">
                    <TextBlock x:Name="DebugOverlayText" FontFamily="Consolas" FontSize="11" Foreground="#1A2530" TextWrapping="Wrap" Width="420"/>
                </Border>
            </Grid>

            <TabControl x:Name="DiagnosticsTabControl" Grid.Row="1" Margin="0,8,0,8" SelectionChanged="DiagnosticsTabControl_SelectionChanged">
                <TabItem Header="런타임 (Runtime)">
                    <TextBox x:Name="RuntimeDiagnosticsTextBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                </TabItem>
                <TabItem Header="아바타 (Avatar)">
                    <TextBox x:Name="AvatarDiagnosticsTextBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                </TabItem>
                <TabItem Header="로그 (Logs)">
                    <DockPanel>
                        <Button Content="로그 복사" DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0,0,0,8" Padding="10,4" Click="CopyLogs_Click"/>
                        <TextBox x:Name="LogsTextBox" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="가이드 (Guides)">
                    <TextBox x:Name="GuidesTextBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Padding="8" Background="#0F1720" BorderBrush="#2D3A48" BorderThickness="1" CornerRadius="4">
                <WrapPanel>
                    <TextBlock Text="Session: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="SessionStatusText" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Avatar: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="AvatarStatusText" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Render: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="RenderStatusText" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Frame: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="FrameStatusText" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Outputs: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="OutputStatusText" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Busy: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="BusyStatusText" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBlock Text="LastError: " Foreground="#A7B7C7"/>
                    <TextBlock x:Name="ErrorStatusText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Width="360"/>
                    <TextBlock Text="Track: " Foreground="#A7B7C7" Margin="12,0,0,0"/>
                    <TextBlock x:Name="TrackStatusText" FontWeight="SemiBold" Width="300" TextTrimming="CharacterEllipsis"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</Window>




