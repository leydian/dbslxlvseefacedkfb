<Window
    x:Class="WinUiHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VsfClone Host (WinUI)">
    <Grid Padding="12" MinWidth="1240" MinHeight="760">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderThickness="1" BorderBrush="#BCD8F3" Background="#EAF4FF" Padding="10" Margin="0,0,0,8" CornerRadius="6">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="QuickNextActionText" Grid.Column="0" Text="Step 1. Start Session" FontSize="17" FontWeight="SemiBold" Foreground="#11395B"/>
                        <Border Grid.Column="1" Background="#EFF3F9" BorderBrush="#CFD9E6" BorderThickness="1" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="ActionabilityBadgeText" Text="READY" FontSize="11" FontWeight="SemiBold" Foreground="#43586E"/>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="PrimaryActionDescriptionText" Text="Initialize to prepare rendering and output runtime." Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#2A4A67"/>
                    <TextBlock x:Name="NextActionSummaryText" Text="Start session to unlock avatar import." Margin="0,3,0,0" TextWrapping="Wrap" Foreground="#2A4A67" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BlockReasonShortText" Margin="0,3,0,0" TextWrapping="Wrap" Foreground="#A56B1A" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                        <Button x:Name="PrimaryActionButton" Content="세션 시작" Click="PrimaryAction_Click" MinWidth="170" MinHeight="38"/>
                        <Button x:Name="QuickInitializeButton" Content="세션" Click="QuickInitialize_Click" MinWidth="76"/>
                        <Button x:Name="QuickLoadAvatarButton" Content="아바타" Click="QuickLoadAvatar_Click" MinWidth="76"/>
                        <Button x:Name="QuickStartBroadcastButton" Content="출력" Click="QuickStartBroadcast_Click" MinWidth="76"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" BorderThickness="1" BorderBrush="#D7E3F2" Background="#F3F7FD" Padding="8" Margin="0,0,0,8" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="1) 세션 시작" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="OnboardingStep1Text" Text="대기" Margin="0,2,0,0" Foreground="#35516B"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="2) 아바타 불러오기" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="OnboardingStep2Text" Text="대기" Margin="0,2,0,0" Foreground="#35516B"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="3) 출력 시작" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="OnboardingStep3Text" Text="대기" Margin="0,2,0,0" Foreground="#35516B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="현재 상태 (Status)" FontSize="16"/>
                    <TextBlock x:Name="QuickStatusText" Text="Session=Stopped | Avatar=None | Outputs=Off" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OnboardingRecoveryText" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed" Foreground="#7C4012"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button x:Name="OpenDiagnosticsFromHintButton" Content="Open Diagnostics" Click="OpenDiagnosticsFromHint_Click" MinWidth="140" Visibility="Collapsed"/>
                        <Button x:Name="DismissRecoveryHintButton" Content="Dismiss" Click="DismissRecoveryHint_Click" MinWidth="90" Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="세션 (Session)" FontSize="16"/>
                    <TextBlock Text="세션 수명주기 제어입니다. 아바타를 불러오기 전에 초기화를 실행하세요." TextWrapping="Wrap" Margin="0,4,0,8"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="InitializeButton" Content="초기화 (Initialize)" Click="Initialize_Click" MinWidth="92"/>
                        <Button x:Name="ShutdownButton" Content="종료 (Shutdown)" Click="Shutdown_Click" MinWidth="92"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="아바타 (Avatar)" FontSize="16"/>
                    <TextBlock Text="아바타 파일 경로 (Avatar Path)" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm" TextChanged="InputTextChanged"/>
                        <Button Grid.Column="1" x:Name="BrowseAvatarButton" Content="찾아보기..." Click="BrowseAvatar_Click" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="AvatarPathValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <Border BorderBrush="#D7E0EA" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="120" Height="120" BorderBrush="#CCD8E6" BorderThickness="1" Background="#F5F9FE" CornerRadius="4" VerticalAlignment="Top">
                                <Image x:Name="AvatarPreviewImage" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="현재 선택 미리보기" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AvatarPreviewStatusText" Text="선택된 파일 없음" Margin="0,4,0,8" TextWrapping="Wrap" Foreground="#5E6B78"/>
                                <Button x:Name="RetryAvatarPreviewButton" Content="미리보기 재생성" Click="RetryAvatarPreview_Click" MinWidth="120" HorizontalAlignment="Left"/>
                                <TextBlock Text="최근 사용 아바타" FontWeight="SemiBold" Margin="0,10,0,4"/>
                                <ListBox x:Name="RecentAvatarListBox" Height="100" SelectionChanged="RecentAvatarList_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="LoadButton" Content="불러오기 (Load)" Click="Load_Click" MinWidth="92"/>
                        <Button x:Name="CancelLoadButton" Content="불러오기 취소" Click="CancelLoad_Click" MinWidth="92"/>
                        <Button x:Name="UnloadButton" Content="해제 (Unload)" Click="Unload_Click" MinWidth="92"/>
                    </StackPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Timeout" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="LoadTimeoutTextBox" Text="20000"/>
                        <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Grid>
                    <ProgressBar x:Name="LoadProgressBar" Minimum="0" Maximum="100" Value="0" Margin="0,8,0,0"/>
                    <TextBlock x:Name="LoadProgressText" Text="Load progress: idle" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="렌더 (Render)" FontSize="16"/>
                    <CheckBox x:Name="BroadcastModeCheckBox" Content="방송 모드 (Broadcast Mode)" IsChecked="True" Checked="BroadcastMode_Changed" Unchecked="BroadcastMode_Changed" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Camera" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CameraModeComboBox" SelectionChanged="CameraMode_SelectionChanged">
                            <x:String>Auto Fit Full</x:String>
                            <x:String>Auto Fit Bust</x:String>
                            <x:String>Manual</x:String>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Framing" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="FramingSlider" Minimum="0.35" Maximum="0.95" Value="0.72" StepFrequency="0.01" ValueChanged="FramingSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="FramingValueText" Text="0.72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Headroom" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="HeadroomSlider" Minimum="0.00" Maximum="0.50" Value="0.10" StepFrequency="0.01" ValueChanged="HeadroomSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="HeadroomValueText" Text="0.10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Yaw" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="YawSlider" Minimum="-180" Maximum="180" Value="0" StepFrequency="1" ValueChanged="YawSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="YawValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="FovSlider" Minimum="20" Maximum="70" Value="35" StepFrequency="1" ValueChanged="FovSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="FovValueText" Text="35" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Background" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="BackgroundPresetComboBox" SelectionChanged="BackgroundPreset_SelectionChanged">
                            <x:String>Dark Blue</x:String>
                            <x:String>Neutral Gray</x:String>
                            <x:String>Green Screen</x:String>
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="MirrorModeCheckBox" Content="미러 모드 (Mirror Mode)" Checked="MirrorMode_Changed" Unchecked="MirrorMode_Changed" Margin="0,0,0,8"/>
                    <CheckBox x:Name="DebugOverlayCheckBox" Content="디버그 오버레이 표시" Checked="DebugOverlay_Changed" Unchecked="DebugOverlay_Changed"/>
                    <Separator Margin="0,10,0,10"/>
                    <TextBlock Text="프리셋 (Presets)"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="PresetNameTextBox" Text="My Preset"/>
                        <Button Grid.Column="1" x:Name="SavePresetButton" Content="Save" Click="SavePreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="PresetComboBox"/>
                        <Button Grid.Column="1" x:Name="ApplyPresetButton" Content="적용" Click="ApplyPreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                        <Button Grid.Column="2" x:Name="DeletePresetButton" Content="삭제" Click="DeletePreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                    </Grid>
                    <Button x:Name="ResetRenderButton" Content="Reset To Default" Click="ResetRender_Click" MinWidth="132"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" BorderThickness="1" BorderBrush="#2D3A48" Padding="8">
                <StackPanel>
                    <TextBlock Text="출력 (Outputs)" FontSize="16"/>
                    <TextBlock Text="Spout" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Channel" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SpoutChannelTextBox" Text="VsfClone"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                        <Button x:Name="StartSpoutButton" Content="Spout 시작" Click="StartSpout_Click" MinWidth="110"/>
                        <Button x:Name="StopSpoutButton" Content="Spout 중지" Click="StopSpout_Click" MinWidth="110"/>
                    </StackPanel>

                    <TextBlock Text="OSC" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind Port" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="OscBindPortTextBox" Text="39539" TextChanged="InputTextChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Publish" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="OscPublishAddressTextBox" Text="127.0.0.1:39540" Margin="0,8,0,0" TextChanged="InputTextChanged"/>
                    </Grid>
                    <TextBlock x:Name="OscBindValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OscPublishValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="StartOscButton" Content="OSC 시작" Click="StartOsc_Click" MinWidth="110"/>
                        <Button x:Name="StopOscButton" Content="OSC 중지" Click="StopOsc_Click" MinWidth="110"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="7" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="트래킹 입력 (Tracking Input)" FontSize="16"/>
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Column="0" Text="Listen Port" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="TrackingPortTextBox" Text="49983"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Source" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TrackingSourceComboBox" Margin="0,8,0,0">
                            <x:String>Auto (OSC + Webcam)</x:String>
                            <x:String>OSC (iFacialMocap)</x:String>
                            <x:String>Webcam (MediaPipe)</x:String>
                        </ComboBox>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Webcam" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" x:Name="TrackingWebcamDeviceComboBox"/>
                            <Button Grid.Column="1" x:Name="RefreshTrackingWebcamButton" Content="새로고침" Click="RefreshTrackingWebcam_Click" Margin="8,0,0,0" MinWidth="70"/>
                        </Grid>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Infer FPS" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TrackingInferenceFpsTextBox" Text="30" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Parse Warn" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TrackingParseWarnThresholdTextBox" Text="10" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Drop Warn" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="TrackingDropWarnThresholdTextBox" Text="10" Margin="0,8,0,0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button x:Name="StartTrackingButton" Content="트래킹 시작" Click="StartTracking_Click" MinWidth="110"/>
                        <Button x:Name="StopTrackingButton" Content="트래킹 중지" Click="StopTracking_Click" MinWidth="110"/>
                        <Button x:Name="RecenterTrackingButton" Content="Recenter" Click="RecenterTracking_Click" MinWidth="96"/>
                    </StackPanel>
                    <TextBlock x:Name="TrackingStatusText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="8" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="운영/진단 (Platform Ops)" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                        <Button x:Name="RunPreflightButton" Content="사전 점검 실행" Click="RunPreflight_Click" MinWidth="112"/>
                        <Button x:Name="ExportDiagButton" Content="진단 내보내기" Click="ExportDiag_Click" MinWidth="128"/>
                        <Button x:Name="ExportMetricsButton" Content="메트릭 내보내기" Click="ExportMetrics_Click" MinWidth="112"/>
                    </StackPanel>
                    <TextBlock x:Name="PreflightHintText" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <TextBlock Text="렌더 프로파일 (Render Profiles)"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,8">
                        <Button Content="Quality" Click="ProfileQuality_Click" MinWidth="92"/>
                        <Button Content="Performance" Click="ProfilePerformance_Click" MinWidth="92"/>
                        <Button Content="Stability" Click="ProfileStability_Click" MinWidth="92"/>
                    </StackPanel>

                    <TextBlock Text="Sidecar 설정 (Sidecar Settings)"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ParserModeComboBox">
                            <x:String>sidecar</x:String>
                            <x:String>inhouse</x:String>
                            <x:String>sidecar-strict</x:String>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="SidecarPathTextBox" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Timeout" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="SidecarTimeoutTextBox" Text="15000" Margin="0,8,0,0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <CheckBox x:Name="SidecarStrictCheckBox" Content="엄격 모드 (Strict, no fallback)"/>
                        <Button Content="Sidecar 적용" Click="ApplySidecar_Click" MinWidth="112"/>
                    </StackPanel>

                    <TextBlock Text="텔레메트리 (Telemetry)"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,8">
                        <CheckBox x:Name="TelemetryOptInCheckBox" Content="수집 동의 (Opt-in)"/>
                        <CheckBox x:Name="TelemetryRedactCheckBox" Content="Redact Sensitive" IsChecked="True"/>
                        <Button Content="Telemetry 적용" Click="ApplyTelemetry_Click" MinWidth="112"/>
                        <Button Content="Telemetry 내보내기" Click="ExportTelemetry_Click" MinWidth="120"/>
                    </StackPanel>

                    <TextBlock Text="자동 품질 정책 (Auto Quality)"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Threshold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="AutoQualityThresholdTextBox" Text="28.0"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Consecutive" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="AutoQualityConsecutiveTextBox" Text="120" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cooldown" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="AutoQualityCooldownTextBox" Text="30" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Recovery ms" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="AutoQualityRecoveryThresholdTextBox" Text="22.0" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Recovery n" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="AutoQualityRecoveryConsecutiveTextBox" Text="240" Margin="0,8,0,0"/>
                    </Grid>
                    <Button Content="자동 품질 정책 적용" Click="ApplyAutoQualityPolicy_Click" MinWidth="180"/>
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border x:Name="RenderHost" Background="#111722" BorderBrush="#304050" BorderThickness="1"/>
                <Border x:Name="DebugOverlayPanel" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Padding="8" Background="#EEFFFFFF" BorderBrush="#203040" BorderThickness="1">
                    <TextBlock x:Name="DebugOverlayText" FontFamily="Consolas" FontSize="11" Foreground="#1A2530" TextWrapping="Wrap" Width="420"/>
                </Border>
            </Grid>

            <TabView Grid.Row="1" x:Name="DiagnosticsTabControl" Margin="0,8,0,8" SelectionChanged="DiagnosticsTabControl_SelectionChanged">
                <TabViewItem Header="런타임 (Runtime)">
                    <TextBox x:Name="RuntimeDiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </TabViewItem>
                <TabViewItem Header="아바타 (Avatar)">
                    <TextBox x:Name="AvatarDiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </TabViewItem>
                <TabViewItem Header="로그 (Logs)">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Logs" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="로그 복사" Click="CopyLogs_Click"/>
                        </Grid>
                        <TextBox x:Name="LogsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,4,0,0"/>
                    </StackPanel>
                </TabViewItem>
                <TabViewItem Header="가이드 (Guides)">
                    <TextBox x:Name="GuidesTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </TabViewItem>
            </TabView>

            <Border Grid.Row="2" Padding="8" Background="#0F1720" BorderBrush="#2D3A48" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="SessionStatusText" Foreground="#D7E6F5"/>
                    <TextBlock x:Name="AvatarStatusText" Foreground="#D7E6F5"/>
                    <TextBlock x:Name="RenderStatusText" Foreground="#D7E6F5"/>
                    <TextBlock x:Name="FrameStatusText" Foreground="#D7E6F5"/>
                    <TextBlock x:Name="OutputStatusText" Foreground="#D7E6F5"/>
                    <TextBlock x:Name="BusyStatusText" Foreground="#D7E6F5"/>
                    <TextBlock x:Name="ErrorStatusText" Foreground="#F2B8B5"/>
                    <TextBlock x:Name="TrackStatusText" Foreground="#D7E6F5"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
