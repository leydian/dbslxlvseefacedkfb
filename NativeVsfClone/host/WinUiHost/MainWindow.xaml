<Window
    x:Class="WinUiHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VsfClone Host (WinUI)">
    <Grid Padding="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Session" FontSize="16"/>
                    <TextBlock Text="Runtime lifecycle controls. Initialize before loading avatars." TextWrapping="Wrap" Margin="0,4,0,8"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="InitializeButton" Content="Initialize" Click="Initialize_Click" MinWidth="92"/>
                        <Button x:Name="ShutdownButton" Content="Shutdown" Click="Shutdown_Click" MinWidth="92"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Avatar" FontSize="16"/>
                    <TextBlock Text="Avatar file path" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm" TextChanged="InputTextChanged"/>
                        <Button Grid.Column="1" x:Name="BrowseAvatarButton" Content="Browse..." Click="BrowseAvatar_Click" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="AvatarPathValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="LoadButton" Content="Load" Click="Load_Click" MinWidth="92"/>
                        <Button x:Name="UnloadButton" Content="Unload" Click="Unload_Click" MinWidth="92"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" BorderThickness="1" BorderBrush="#2D3A48" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Render" FontSize="16"/>
                    <CheckBox x:Name="BroadcastModeCheckBox" Content="Broadcast Mode" IsChecked="True" Checked="BroadcastMode_Changed" Unchecked="BroadcastMode_Changed" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Camera" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CameraModeComboBox" SelectionChanged="CameraMode_SelectionChanged">
                            <x:String>Auto Fit Full</x:String>
                            <x:String>Auto Fit Bust</x:String>
                            <x:String>Manual</x:String>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Framing" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="FramingSlider" Minimum="0.35" Maximum="0.95" Value="0.72" StepFrequency="0.01" ValueChanged="FramingSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="FramingValueText" Text="0.72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Headroom" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="HeadroomSlider" Minimum="0.00" Maximum="0.50" Value="0.10" StepFrequency="0.01" ValueChanged="HeadroomSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="HeadroomValueText" Text="0.10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Yaw" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="YawSlider" Minimum="-45" Maximum="45" Value="0" StepFrequency="1" ValueChanged="YawSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="YawValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="FovSlider" Minimum="20" Maximum="70" Value="35" StepFrequency="1" ValueChanged="FovSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="FovValueText" Text="35" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Background" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="BackgroundPresetComboBox" SelectionChanged="BackgroundPreset_SelectionChanged">
                            <x:String>Dark Blue</x:String>
                            <x:String>Neutral Gray</x:String>
                            <x:String>Green Screen</x:String>
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="MirrorModeCheckBox" Content="Mirror Mode" Checked="MirrorMode_Changed" Unchecked="MirrorMode_Changed" Margin="0,0,0,8"/>
                    <CheckBox x:Name="DebugOverlayCheckBox" Content="Show Debug Overlay" Checked="DebugOverlay_Changed" Unchecked="DebugOverlay_Changed"/>
                    <Separator Margin="0,10,0,10"/>
                    <TextBlock Text="Presets"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="PresetNameTextBox" Text="My Preset"/>
                        <Button Grid.Column="1" x:Name="SavePresetButton" Content="Save" Click="SavePreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="PresetComboBox"/>
                        <Button Grid.Column="1" x:Name="ApplyPresetButton" Content="Apply" Click="ApplyPreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                        <Button Grid.Column="2" x:Name="DeletePresetButton" Content="Delete" Click="DeletePreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                    </Grid>
                    <Button x:Name="ResetRenderButton" Content="Reset To Default" Click="ResetRender_Click" MinWidth="132"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderThickness="1" BorderBrush="#2D3A48" Padding="8">
                <StackPanel>
                    <TextBlock Text="Outputs" FontSize="16"/>
                    <TextBlock Text="Spout" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Channel" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SpoutChannelTextBox" Text="VsfClone"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                        <Button x:Name="StartSpoutButton" Content="Start Spout" Click="StartSpout_Click" MinWidth="110"/>
                        <Button x:Name="StopSpoutButton" Content="Stop Spout" Click="StopSpout_Click" MinWidth="110"/>
                    </StackPanel>

                    <TextBlock Text="OSC" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind Port" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="OscBindPortTextBox" Text="39539" TextChanged="InputTextChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Publish" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="OscPublishAddressTextBox" Text="127.0.0.1:39540" Margin="0,8,0,0" TextChanged="InputTextChanged"/>
                    </Grid>
                    <TextBlock x:Name="OscBindValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OscPublishValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="StartOscButton" Content="Start OSC" Click="StartOsc_Click" MinWidth="110"/>
                        <Button x:Name="StopOscButton" Content="Stop OSC" Click="StopOsc_Click" MinWidth="110"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border x:Name="RenderHost" Background="#111722" BorderBrush="#304050" BorderThickness="1"/>
                <Border x:Name="DebugOverlayPanel" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Padding="8" Background="#EEFFFFFF" BorderBrush="#203040" BorderThickness="1">
                    <TextBlock x:Name="DebugOverlayText" FontFamily="Consolas" FontSize="11" Foreground="#1A2530" TextWrapping="Wrap" Width="420"/>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Runtime" Margin="0,0,0,4"/>
                    <TextBox x:Name="RuntimeDiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="Avatar" Margin="0,0,0,4"/>
                    <TextBox x:Name="AvatarDiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Logs" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Copy Logs" Click="CopyLogs_Click"/>
                    </Grid>
                    <TextBox x:Name="LogsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Padding="8" Background="#0F1720" BorderBrush="#2D3A48" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="SessionStatusText"/>
                    <TextBlock x:Name="AvatarStatusText"/>
                    <TextBlock x:Name="RenderStatusText"/>
                    <TextBlock x:Name="FrameStatusText"/>
                    <TextBlock x:Name="OutputStatusText"/>
                    <TextBlock x:Name="BusyStatusText"/>
                    <TextBlock x:Name="ErrorStatusText"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
