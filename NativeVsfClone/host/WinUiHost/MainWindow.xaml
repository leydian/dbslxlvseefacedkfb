<Window
    x:Class="WinUiHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinUI Host">
    <Grid Padding="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="8">
            <TextBlock Text="Avatar Path"/>
            <TextBox x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Initialize" Click="Initialize_Click"/>
                <Button Content="Load" Click="Load_Click"/>
                <Button Content="Unload" Click="Unload_Click"/>
            </StackPanel>

            <TextBlock Text="Output"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start Spout" Click="StartSpout_Click"/>
                <Button Content="Stop Spout" Click="StopSpout_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start OSC" Click="StartOsc_Click"/>
                <Button Content="Stop OSC" Click="StopOsc_Click"/>
            </StackPanel>

            <TextBlock Text="Diagnostics"/>
            <TextBox x:Name="DiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="380"/>
        </StackPanel>

        <Border Grid.Column="1" x:Name="RenderHost" Background="#111722" BorderBrush="#304050" BorderThickness="1"/>
    </Grid>
</Window>
