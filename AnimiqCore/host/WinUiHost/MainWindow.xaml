<Window
    x:Class="WinUiHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Animiq Host (WinUI)">
    <Window.Resources>
        <SolidColorBrush x:Key="Brush.AppBg" Color="#F4F7FC"/>
        <SolidColorBrush x:Key="Brush.RailBg" Color="#E7EFFA"/>
        <SolidColorBrush x:Key="Brush.CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Brush.CardAltBg" Color="#F6F9FE"/>
        <SolidColorBrush x:Key="Brush.CardBorder" Color="#CDD9EA"/>
        <SolidColorBrush x:Key="Brush.TextPrimary" Color="#1A2736"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#556A7F"/>
        <SolidColorBrush x:Key="Brush.Primary" Color="#0B6FC2"/>
        <SolidColorBrush x:Key="Brush.PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Brush.Warning" Color="#A56B1A"/>
        <SolidColorBrush x:Key="Brush.Error" Color="#B03030"/>
        <SolidColorBrush x:Key="Brush.StatusBg" Color="#1F2F43"/>
        <SolidColorBrush x:Key="Brush.StatusText" Color="#E9F3FF"/>
        <SolidColorBrush x:Key="Brush.OnboardingBg" Color="#EAF4FF"/>
        <SolidColorBrush x:Key="Brush.OnboardingBorder" Color="#BCD8F3"/>
        <SolidColorBrush x:Key="Brush.OnboardingTitle" Color="#11395B"/>
        <SolidColorBrush x:Key="Brush.OnboardingBody" Color="#2A4A67"/>
        <SolidColorBrush x:Key="Brush.BadgeReadyBg" Color="#EFF3F9"/>
        <SolidColorBrush x:Key="Brush.BadgeReadyBorder" Color="#CFD9E6"/>
        <SolidColorBrush x:Key="Brush.BadgeReadyText" Color="#43586E"/>
        <SolidColorBrush x:Key="Brush.BadgeBlockedBg" Color="#FFF3E3"/>
        <SolidColorBrush x:Key="Brush.BadgeBlockedBorder" Color="#F0CCA1"/>
        <SolidColorBrush x:Key="Brush.BadgeBlockedText" Color="#A56B1A"/>
        <SolidColorBrush x:Key="Brush.StepStripBg" Color="#F3F7FD"/>
        <SolidColorBrush x:Key="Brush.StepStripBorder" Color="#D7E3F2"/>
        <SolidColorBrush x:Key="Brush.StepStripText" Color="#35516B"/>

        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.CardBorder}"/>
            <Setter Property="Background" Value="{StaticResource Brush.CardBg}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style x:Key="SoftButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{StaticResource Brush.CardAltBg}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.CardBorder}"/>
        </Style>
    </Window.Resources>
    <Grid Padding="12" MinWidth="1240" MinHeight="760" Background="{StaticResource Brush.AppBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="168"/>
            <ColumnDefinition Width="520"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Brush.RailBg}" Padding="10">
            <StackPanel>
                <TextBlock Text="WORKSPACE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}"/>
                <TextBlock Text="빠른 제어" Margin="0,4,0,12" FontSize="20" FontWeight="SemiBold"/>
                <Border Background="{StaticResource Brush.CardBg}" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="시작하기" FontWeight="SemiBold"/>
                        <TextBlock Text="세션 → 아바타 → 출력" Margin="0,2,0,0" FontSize="12" Foreground="{StaticResource Brush.TextMuted}"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Brush.CardAltBg}" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="실시간 미리보기" FontWeight="SemiBold"/>
                        <TextBlock Text="오른쪽 패널에서 즉시 확인" Margin="0,2,0,0" FontSize="12" Foreground="{StaticResource Brush.TextMuted}"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Brush.CardAltBg}" Padding="10">
                    <StackPanel>
                        <TextBlock Text="고급 운영" FontWeight="SemiBold"/>
                        <TextBlock Text="진단/사전 점검/정책" Margin="0,2,0,0" FontSize="12" Foreground="{StaticResource Brush.TextMuted}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderThickness="1" BorderBrush="{StaticResource Brush.OnboardingBorder}" Background="{StaticResource Brush.OnboardingBg}" Padding="10" Margin="0,0,0,8" CornerRadius="6">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="QuickNextActionText" Grid.Column="0" Text="Step 1. Start Session" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Brush.OnboardingTitle}"/>
                        <Border x:Name="ActionabilityBadgeBorder" Grid.Column="1" Background="{StaticResource Brush.BadgeReadyBg}" BorderBrush="{StaticResource Brush.BadgeReadyBorder}" BorderThickness="1" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="ActionabilityBadgeText" Text="READY" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Brush.BadgeReadyText}"/>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="PrimaryActionDescriptionText" Text="Initialize to prepare rendering and output runtime." Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource Brush.OnboardingBody}"/>
                    <TextBlock x:Name="NextActionSummaryText" Text="Start session to unlock avatar import." Margin="0,3,0,0" TextWrapping="Wrap" Foreground="{StaticResource Brush.OnboardingBody}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BlockReasonShortText" Margin="0,3,0,0" TextWrapping="Wrap" Foreground="{StaticResource Brush.Warning}" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                        <Button x:Name="PrimaryActionButton" Content="세션 시작" Click="PrimaryAction_Click" MinWidth="170" MinHeight="38"/>
                        <Button x:Name="QuickInitializeButton" Style="{StaticResource SoftButtonStyle}" Content="세션" Click="QuickInitialize_Click" MinWidth="76"/>
                        <Button x:Name="QuickLoadAvatarButton" Style="{StaticResource SoftButtonStyle}" Content="아바타" Click="QuickLoadAvatar_Click" MinWidth="76"/>
                        <Button x:Name="QuickStartBroadcastButton" Style="{StaticResource SoftButtonStyle}" Content="출력" Click="QuickStartBroadcast_Click" MinWidth="76"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" BorderThickness="1" BorderBrush="{StaticResource Brush.StepStripBorder}" Background="{StaticResource Brush.StepStripBg}" Padding="8" Margin="0,0,0,8" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="1) 세션 시작" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="OnboardingStep1Text" Text="대기" Margin="0,2,0,0" Foreground="{StaticResource Brush.StepStripText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="2) 아바타 불러오기" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="OnboardingStep2Text" Text="대기" Margin="0,2,0,0" Foreground="{StaticResource Brush.StepStripText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="3) 출력 시작" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="OnboardingStep3Text" Text="대기" Margin="0,2,0,0" Foreground="{StaticResource Brush.StepStripText}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="현재 상태 (Status)" FontSize="16"/>
                    <TextBlock x:Name="QuickStatusText" Text="Session=Stopped | Avatar=None | Outputs=Off" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OnboardingRecoveryText" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed" Foreground="#7C4012"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button x:Name="OpenDiagnosticsFromHintButton" Content="Open Diagnostics" Click="OpenDiagnosticsFromHint_Click" MinWidth="140" Visibility="Collapsed"/>
                        <Button x:Name="DismissRecoveryHintButton" Content="Dismiss" Click="DismissRecoveryHint_Click" MinWidth="90" Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="세션 (Session)" FontSize="16"/>
                    <TextBlock Text="세션 수명주기 제어입니다. 아바타를 불러오기 전에 초기화를 실행하세요." TextWrapping="Wrap" Margin="0,4,0,8"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="InitializeButton" Content="초기화 (Initialize)" Click="Initialize_Click" MinWidth="92"/>
                        <Button x:Name="ShutdownButton" Content="종료 (Shutdown)" Click="Shutdown_Click" MinWidth="92"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="아바타 (Avatar)" FontSize="16"/>
                    <TextBlock Text="아바타 파일 경로 (Avatar Path)" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm" TextChanged="InputTextChanged"/>
                        <Button Grid.Column="1" x:Name="BrowseAvatarButton" Content="찾아보기..." Click="BrowseAvatar_Click" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="AvatarPathValidationText" Foreground="{StaticResource Brush.Error}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <Border BorderBrush="{StaticResource Brush.CardBorder}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="120" Height="120" BorderBrush="#CCD8E6" BorderThickness="1" Background="#F5F9FE" CornerRadius="4" VerticalAlignment="Top">
                                <Image x:Name="AvatarPreviewImage" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="현재 선택 미리보기" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AvatarPreviewStatusText" Text="선택된 파일 없음" Margin="0,4,0,8" TextWrapping="Wrap" Foreground="#5E6B78"/>
                                <Button x:Name="RetryAvatarPreviewButton" Content="미리보기 재생성" Click="RetryAvatarPreview_Click" MinWidth="120" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button x:Name="AvatarFacingToggleButton" Content="앞/뒤 전환 (이 아바타 저장)" Click="AvatarFacingToggle_Click" MinWidth="170"/>
                                    <TextBlock x:Name="AvatarFacingStatusText" Text="저장: 기본" VerticalAlignment="Center" Foreground="{StaticResource Brush.TextMuted}"/>
                                </StackPanel>
                                <TextBlock Text="최근 사용 아바타" FontWeight="SemiBold" Margin="0,10,0,4"/>
                                <ListBox x:Name="RecentAvatarListBox" Height="100" SelectionChanged="RecentAvatarList_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="LoadButton" Content="불러오기 (Load)" Click="Load_Click" MinWidth="92"/>
                        <Button x:Name="CancelLoadButton" Content="불러오기 취소" Click="CancelLoad_Click" MinWidth="92"/>
                        <Button x:Name="UnloadButton" Content="해제 (Unload)" Click="Unload_Click" MinWidth="92"/>
                    </StackPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Timeout" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="LoadTimeoutTextBox" Text="20000"/>
                        <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Grid>
                    <ProgressBar x:Name="LoadProgressBar" Minimum="0" Maximum="100" Value="0" Margin="0,8,0,0"/>
                    <TextBlock x:Name="LoadProgressText" Text="Load progress: idle" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="렌더 (Render)" FontSize="16"/>
                    <CheckBox x:Name="BroadcastModeCheckBox" Content="방송 모드 (Broadcast Mode)" IsChecked="True" Checked="BroadcastMode_Changed" Unchecked="BroadcastMode_Changed" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Camera" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CameraModeComboBox" SelectionChanged="CameraMode_SelectionChanged">
                            <x:String>Auto Fit Full</x:String>
                            <x:String>Auto Fit Bust</x:String>
                            <x:String>Manual</x:String>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Framing" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="FramingSlider" Minimum="0.35" Maximum="0.95" Value="0.72" StepFrequency="0.01" ValueChanged="FramingSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="FramingValueText" Text="0.72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Headroom" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="HeadroomSlider" Minimum="0.00" Maximum="0.50" Value="0.10" StepFrequency="0.01" ValueChanged="HeadroomSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="HeadroomValueText" Text="0.10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Yaw" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="YawSlider" Minimum="-180" Maximum="180" Value="0" StepFrequency="1" ValueChanged="YawSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="YawValueText" Text="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FOV" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="FovSlider" Minimum="20" Maximum="70" Value="35" StepFrequency="1" ValueChanged="FovSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="FovValueText" Text="35" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Background" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="BackgroundPresetComboBox" SelectionChanged="BackgroundPreset_SelectionChanged">
                            <x:String>Dark Blue</x:String>
                            <x:String>Neutral Gray</x:String>
                            <x:String>Green Screen</x:String>
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="Realtime Shadow" FontWeight="SemiBold" Margin="0,2,0,6"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Light X" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="LightPitchSlider" Minimum="-180" Maximum="180" Value="19.201" StepFrequency="1" ValueChanged="LightEulerSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="LightPitchValueText" Text="19" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Light Y" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="LightYawSlider" Minimum="-180" Maximum="180" Value="175.0" StepFrequency="1" ValueChanged="LightEulerSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="LightYawValueText" Text="175" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Intensity" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="LightIntensitySlider" Minimum="0" Maximum="24" Value="12.5" StepFrequency="0.1" ValueChanged="LightIntensitySlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="LightIntensityValueText" Text="12.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Range" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="LightRangeSlider" Minimum="1" Maximum="60" Value="16.4" StepFrequency="0.1" ValueChanged="LightRangeSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="LightRangeValueText" Text="16.4" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Spot" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="SpotAngleSlider" Minimum="1" Maximum="120" Value="16.6" StepFrequency="0.1" ValueChanged="SpotAngleSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="SpotAngleValueText" Text="16.6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Shadow" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="ShadowStrengthSlider" Minimum="0" Maximum="1" Value="1.0" StepFrequency="0.01" ValueChanged="ShadowStrengthSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="ShadowStrengthValueText" Text="1.00" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bias" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="ShadowBiasSlider" Minimum="0" Maximum="1" Value="0.1" StepFrequency="0.01" ValueChanged="ShadowBiasSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="ShadowBiasValueText" Text="0.10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ambient" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="AmbientIntensitySlider" Minimum="0" Maximum="2" Value="1.0" StepFrequency="0.01" ValueChanged="AmbientIntensitySlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="AmbientIntensityValueText" Text="1.00" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <CheckBox x:Name="ShadowEnabledCheckBox" Content="Enable realtime shadow" IsChecked="True" Checked="ShadowEnabled_Changed" Unchecked="ShadowEnabled_Changed" Margin="0,0,0,8"/>
                    <CheckBox x:Name="MirrorModeCheckBox" Content="미러 모드 (Mirror Mode)" Checked="MirrorMode_Changed" Unchecked="MirrorMode_Changed" Margin="0,0,0,8"/>
                    <CheckBox x:Name="DebugOverlayCheckBox" Content="디버그 오버레이 표시" Checked="DebugOverlay_Changed" Unchecked="DebugOverlay_Changed"/>
                    <Separator Margin="0,10,0,10"/>
                    <TextBlock Text="프리셋 (Presets)"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="PresetNameTextBox" Text="My Preset"/>
                        <Button Grid.Column="1" x:Name="SavePresetButton" Content="Save" Click="SavePreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="PresetComboBox"/>
                        <Button Grid.Column="1" x:Name="ApplyPresetButton" Content="적용" Click="ApplyPreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                        <Button Grid.Column="2" x:Name="DeletePresetButton" Content="삭제" Click="DeletePreset_Click" Margin="8,0,0,0" MinWidth="74"/>
                    </Grid>
                    <Button x:Name="ResetRenderButton" Content="Reset To Default" Click="ResetRender_Click" MinWidth="132"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8">
                <StackPanel>
                    <TextBlock Text="출력 (Outputs)" FontSize="16"/>
                    <TextBlock Text="Spout" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Channel" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SpoutChannelTextBox" Text="Animiq"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                        <Button x:Name="StartSpoutButton" Content="Spout 시작" Click="StartSpout_Click" MinWidth="110"/>
                        <Button x:Name="StopSpoutButton" Content="Spout 중지" Click="StopSpout_Click" MinWidth="110"/>
                    </StackPanel>

                    <TextBlock Text="OSC" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind Port" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="OscBindPortTextBox" Text="39539" TextChanged="InputTextChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Publish" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="OscPublishAddressTextBox" Text="127.0.0.1:39540" Margin="0,8,0,0" TextChanged="InputTextChanged"/>
                    </Grid>
                    <TextBlock x:Name="OscBindValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OscPublishValidationText" Foreground="#B03030" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button x:Name="StartOscButton" Content="OSC 시작" Click="StartOsc_Click" MinWidth="110"/>
                        <Button x:Name="StopOscButton" Content="OSC 중지" Click="StopOsc_Click" MinWidth="110"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="7" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="트래킹 입력 (Tracking Input)" FontSize="16"/>
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Column="0" Text="Listen Port" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="TrackingPortTextBox" Text="49983"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Source" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TrackingSourceComboBox" Margin="0,8,0,0">
                            <x:String>Auto (OSC + Webcam)</x:String>
                            <x:String>OSC (iFacialMocap)</x:String>
                            <x:String>Webcam (MediaPipe)</x:String>
                        </ComboBox>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Webcam" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" x:Name="TrackingWebcamDeviceComboBox"/>
                            <Button Grid.Column="1" x:Name="RefreshTrackingWebcamButton" Content="새로고침" Click="RefreshTrackingWebcam_Click" Margin="8,0,0,0" MinWidth="70"/>
                        </Grid>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Infer FPS" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TrackingInferenceFpsTextBox" Text="30" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Parse Warn" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TrackingParseWarnThresholdTextBox" Text="10" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Drop Warn" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="TrackingDropWarnThresholdTextBox" Text="10" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Upper Body" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <CheckBox Grid.Row="6" Grid.Column="1" x:Name="TrackingUpperBodyEnabledCheckBox" Content="자동 상반신 트래킹" Margin="0,8,0,0"/>
                    </Grid>
                    <Border x:Name="TrackingIpv4HintPanel" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="iFacialMocap 대상 PC IPv4" FontWeight="SemiBold"/>
                            <TextBlock Text="Recommended IPv4:" Margin="0,4,0,0" Foreground="#5E6B78"/>
                            <TextBlock x:Name="TrackingIpv4RecommendedText" Text="-" FontFamily="Consolas" FontWeight="SemiBold"/>
                            <TextBlock Text="All IPv4:" Margin="0,4,0,0" Foreground="#5E6B78"/>
                            <TextBlock x:Name="TrackingIpv4AllText" Text="-" FontFamily="Consolas" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button x:Name="TrackingIpv4CopyButton" Content="IPv4 복사" Click="CopyTrackingIpv4_Click" MinWidth="110"/>
                        <Button x:Name="TrackingIpv4ToggleButton" Content="IPv4 안내 숨기기" Click="ToggleTrackingIpv4Hint_Click" MinWidth="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button x:Name="StartTrackingButton" Content="트래킹 시작" Click="StartTracking_Click" MinWidth="110"/>
                        <Button x:Name="StopTrackingButton" Content="트래킹 중지" Click="StopTracking_Click" MinWidth="110"/>
                        <Button x:Name="RecenterTrackingButton" Content="Recenter" Click="RecenterTracking_Click" MinWidth="96"/>
                    </StackPanel>
                    <TextBlock x:Name="TrackingStatusText" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="8" BorderThickness="1" BorderBrush="{StaticResource Brush.CardBorder}" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="운영/진단 (Platform Ops)" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                        <Button x:Name="RunPreflightButton" Content="사전 점검 실행" Click="RunPreflight_Click" MinWidth="112"/>
                        <Button x:Name="ExportDiagButton" Content="진단 내보내기" Click="ExportDiag_Click" MinWidth="128"/>
                        <Button x:Name="ExportMetricsButton" Content="메트릭 내보내기" Click="ExportMetrics_Click" MinWidth="112"/>
                    </StackPanel>
                    <TextBlock x:Name="PreflightHintText" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <TextBlock Text="렌더 프로파일 (Render Profiles)"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,8">
                        <Button Content="Quality" Click="ProfileQuality_Click" MinWidth="92"/>
                        <Button Content="Performance" Click="ProfilePerformance_Click" MinWidth="92"/>
                        <Button Content="Stability" Click="ProfileStability_Click" MinWidth="92"/>
                    </StackPanel>

                    <TextBlock Text="Sidecar 설정 (Sidecar Settings)"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ParserModeComboBox">
                            <x:String>sidecar</x:String>
                            <x:String>inhouse</x:String>
                            <x:String>sidecar-strict</x:String>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="SidecarPathTextBox" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Timeout" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="SidecarTimeoutTextBox" Text="15000" Margin="0,8,0,0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <CheckBox x:Name="SidecarStrictCheckBox" Content="엄격 모드 (Strict, no fallback)"/>
                        <Button Content="Sidecar 적용" Click="ApplySidecar_Click" MinWidth="112"/>
                    </StackPanel>

                    <TextBlock Text="텔레메트리 (Telemetry)"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,8">
                        <CheckBox x:Name="TelemetryOptInCheckBox" Content="수집 동의 (Opt-in)"/>
                        <CheckBox x:Name="TelemetryRedactCheckBox" Content="Redact Sensitive" IsChecked="True"/>
                        <Button Content="Telemetry 적용" Click="ApplyTelemetry_Click" MinWidth="112"/>
                        <Button Content="Telemetry 내보내기" Click="ExportTelemetry_Click" MinWidth="120"/>
                    </StackPanel>

                    <TextBlock Text="자동 품질 정책 (Auto Quality)"/>
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Threshold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="AutoQualityThresholdTextBox" Text="28.0"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Consecutive" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="AutoQualityConsecutiveTextBox" Text="120" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cooldown" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="AutoQualityCooldownTextBox" Text="30" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Recovery ms" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="AutoQualityRecoveryThresholdTextBox" Text="22.0" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Recovery n" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="AutoQualityRecoveryConsecutiveTextBox" Text="240" Margin="0,8,0,0"/>
                    </Grid>
                    <Button Content="자동 품질 정책 적용" Click="ApplyAutoQualityPolicy_Click" MinWidth="180"/>
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <Grid Grid.Column="2" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border x:Name="RenderHost" Background="#111722" BorderBrush="#304050" BorderThickness="1"/>
                <Border x:Name="DebugOverlayPanel" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12" Padding="8" Background="#EEFFFFFF" BorderBrush="#203040" BorderThickness="1">
                    <TextBlock x:Name="DebugOverlayText" FontFamily="Consolas" FontSize="11" Foreground="#1A2530" TextWrapping="Wrap" Width="420"/>
                </Border>
            </Grid>

            <TabView Grid.Row="1" x:Name="DiagnosticsTabControl" Margin="0,8,0,8" SelectionChanged="DiagnosticsTabControl_SelectionChanged">
                <TabViewItem Header="런타임 (Runtime)">
                    <TextBox x:Name="RuntimeDiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </TabViewItem>
                <TabViewItem Header="아바타 (Avatar)">
                    <TextBox x:Name="AvatarDiagnosticsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </TabViewItem>
                <TabViewItem Header="로그 (Logs)">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Logs" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="로그 복사" Click="CopyLogs_Click"/>
                        </Grid>
                        <TextBox x:Name="LogsTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,4,0,0"/>
                    </StackPanel>
                </TabViewItem>
                <TabViewItem Header="가이드 (Guides)">
                    <TextBox x:Name="GuidesTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </TabViewItem>
            </TabView>

            <Border Grid.Row="2" Padding="8" Background="{StaticResource Brush.StatusBg}" BorderBrush="{StaticResource Brush.CardBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="SessionStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                    <TextBlock x:Name="AvatarStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                    <TextBlock x:Name="RenderStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                    <TextBlock x:Name="FrameStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                    <TextBlock x:Name="OutputStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                    <TextBlock x:Name="BusyStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                    <TextBlock x:Name="ErrorStatusText" Foreground="#F2B8B5"/>
                    <TextBlock x:Name="TrackStatusText" Foreground="{StaticResource Brush.StatusText}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

