<Window x:Class="WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfHost"
        Title="Animiq Host (WPF)" Icon="Assets/app.ico" Height="840" Width="1420" MinHeight="760" MinWidth="1240"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Window.Resources>
        <LinearGradientBrush x:Key="Brush.AppBackdrop" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E8E2FF" Offset="0.0"/>
            <GradientStop Color="#EDE5FF" Offset="0.35"/>
            <GradientStop Color="#DDD5F5" Offset="0.7"/>
            <GradientStop Color="#E5DEFF" Offset="1.0"/>
        </LinearGradientBrush>

        <Style x:Key="SectionCardStyle" TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Color.BorderStrong}"/>
            <Setter Property="Background" Value="{DynamicResource Color.CardStrong}"/>
        </Style>

        <Style x:Key="NavRailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Color.NavItemText}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Color.NavItemBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Color.NavItemActiveText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.NavActive}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Color.FocusRing}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ControlsColumn" Width="640" />
            <ColumnDefinition x:Name="SplitterColumn" Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{StaticResource Brush.AppBackdrop}" CornerRadius="12" />

        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="192"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftRailPanel"
                    Grid.Column="0"
                    Background="{DynamicResource Color.NavRailBg}"
                    BorderThickness="0"
                    CornerRadius="18">
                <DockPanel LastChildFill="True">
                    <!-- App brand area (top) -->
                    <Border DockPanel.Dock="Top"
                            CornerRadius="18,18,0,0"
                            Padding="14,20,14,16"
                            Background="#251450">
                        <StackPanel>
                            <Border Width="40" Height="40" CornerRadius="12"
                                    HorizontalAlignment="Left" Margin="0,0,0,10"
                                    Background="#140934">
                                <Image Width="32" Height="32"
                                       Source="pack://application:,,,/Assets/brand-icon.png"
                                       Stretch="Uniform"/>
                            </Border>
                            <Image Height="26"
                                   HorizontalAlignment="Left"
                                   Stretch="Uniform"
                                   Source="pack://application:,,,/Assets/brand-logo.png"/>
                            <TextBlock Text="Studio" Foreground="#C4B5FD"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- 모델 창 분리 버튼 (진단 버튼 위) -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="10,0,10,4"
                            BorderThickness="0">
                        <Button x:Name="PopOutRenderButton"
                                Style="{StaticResource NavRailButtonStyle}"
                                Content="🖼  모델 창 분리"
                                Click="PopOutRender_Click"
                                ToolTip="아바타 렌더만 별도 창으로 표시"/>
                    </Border>
                    <!-- Diagnostics button (bottom) -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="10,8,10,10"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="0,1,0,0">
                        <Button x:Name="ToggleDiagnosticsButton" Style="{StaticResource NavRailButtonStyle}" Content="📊  진단 패널" Click="ToggleDiagnosticsPanel_Click" ToolTip="Ctrl+D"/>
                    </Border>
                    <!-- Navigation items (fill) -->
                    <StackPanel Margin="10,8,10,0">
                        <TextBlock Text="M E N U" Foreground="#A899D4"
                                   FontSize="9" FontWeight="SemiBold"
                                   Margin="12,0,0,8"/>
                        <Button x:Name="NavGettingStartedButton" Style="{StaticResource NavRailButtonStyle}" Content="⚡  시작하기" Click="NavGettingStarted_Click" ToolTip="Ctrl+1"/>
                        <Button x:Name="NavSessionAvatarButton" Style="{StaticResource NavRailButtonStyle}" Content="🎭  세션/아바타" Click="NavSessionAvatar_Click" ToolTip="Ctrl+2"/>
                        <Button x:Name="NavRenderButton" Style="{StaticResource NavRailButtonStyle}" Content="🖥  렌더 설정" Click="NavRender_Click" ToolTip="Ctrl+3"/>
                        <Button x:Name="NavOutputsButton" Style="{StaticResource NavRailButtonStyle}" Content="📡  출력 설정" Click="NavOutputs_Click" ToolTip="Ctrl+4"/>
                        <Button x:Name="NavTrackingButton" Style="{StaticResource NavRailButtonStyle}" Content="🎯  트래킹" Click="NavTracking_Click" ToolTip="Ctrl+5"/>
                        <Button x:Name="NavOpsButton" Style="{StaticResource NavRailButtonStyle}" Content="⚙  고급 운영" Click="NavPlatformOps_Click" ToolTip="Ctrl+6"/>
                        <Border Height="1" Background="#2D2060" Margin="0,10,0,10"/>
                        <Border Background="#231550" CornerRadius="10"
                                Padding="12,10" Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="권장 순서" Foreground="#A899D4"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock Text="① 세션  ②  아바타  ③ 출력"
                                           Foreground="#C4B5FD" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource Color.BorderStrong}" CornerRadius="3"/>

            <Border x:Name="ControlPanelFrame" Grid.Column="2" Background="Transparent" BorderThickness="0" CornerRadius="0" Padding="8,6,6,6">
            <ScrollViewer x:Name="ControlPanelScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,2">
                <GroupBox x:Name="ModeGroup" Style="{StaticResource SectionCardStyle}" Header="화면 설정" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="기본은 초급 보기입니다. 고급 보기를 켜면 운영/진단 메뉴가 열립니다." TextWrapping="Wrap" Foreground="{DynamicResource Color.TextMuted}" Margin="0,0,0,8"/>
                        <StackPanel>
                            <Button x:Name="ViewModeToggleButton" Style="{StaticResource SecondaryButtonStyle}" Content="고급 보기로 전환" Click="ViewModeToggle_Click" Margin="0,0,0,4"/>
                            <UniformGrid Columns="2" Rows="1">
                                <Button x:Name="RenderOnlyToggleButton" Style="{StaticResource SecondaryButtonStyle}" Content="렌더 전용 모드 (F11)" Click="RenderOnlyToggle_Click" Margin="0,0,4,0"/>
                                <Button x:Name="ThemeToggleButton" Style="{StaticResource SecondaryButtonStyle}" Content="다크 테마" Click="ThemeToggle_Click" Margin="4,0,0,0" ToolTip="Ctrl+T"/>
                            </UniformGrid>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="QuickActionsGroup" Style="{StaticResource SectionCardStyle}" Header="시작하기" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="처음에는 이 3단계만 따라오면 됩니다: 세션 시작 -> 아바타 불러오기 -> 출력 시작" TextWrapping="Wrap" Foreground="{DynamicResource Color.TextMuted}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource Color.OnboardingBarBg}" BorderBrush="{DynamicResource Color.OnboardingBarBorder}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Right" Background="{DynamicResource Color.BadgeNeutralBg}" BorderBrush="{DynamicResource Color.Border}" BorderThickness="1" CornerRadius="10" Padding="8,3" Margin="8,0,0,0">
                                        <TextBlock x:Name="ActionabilityBadgeText" Text="진행 가능" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Color.BadgeNeutralText}"/>
                                    </Border>
                                    <TextBlock x:Name="QuickNextActionText" Text="1단계. 세션 시작" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource Color.OnboardingBarTitle}"/>
                                </DockPanel>
                                <TextBlock x:Name="PrimaryActionDescriptionText" Text="먼저 세션을 시작해 주세요." Margin="0,5,0,0" TextWrapping="Wrap" Foreground="{DynamicResource Color.OnboardingBarBody}"/>
                                <TextBlock x:Name="NextActionSummaryText" Text="세션을 시작하면 아바타를 불러올 수 있어요." Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource Color.OnboardingBarBody}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="BlockReasonShortText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource Color.Warning}" Visibility="Collapsed"/>
                                <Button x:Name="PrimaryActionButton" Content="세션 시작" Click="PrimaryAction_Click" MinHeight="44" FontWeight="SemiBold" Margin="0,10,0,8" HorizontalAlignment="Stretch"/>
                                <UniformGrid Columns="3">
                                    <Button x:Name="QuickInitializeButton" Style="{StaticResource SecondaryButtonStyle}" Content="세션" Click="QuickInitialize_Click" Margin="0,0,4,0"/>
                                    <Button x:Name="QuickLoadAvatarButton" Style="{StaticResource SecondaryButtonStyle}" Content="아바타" Click="QuickLoadAvatar_Click" Margin="4,0,4,0"/>
                                    <Button x:Name="QuickStartBroadcastButton" Style="{StaticResource SecondaryButtonStyle}" Content="출력" Click="QuickStartBroadcast_Click" Margin="4,0,0,0"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Border Background="{DynamicResource Color.PanelInfoBg}" BorderBrush="{DynamicResource Color.PanelInfoBorder}" BorderThickness="1" CornerRadius="10" Padding="9" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="1) 세션 시작" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="OnboardingStep1Text" Text="다음 단계" Margin="0,2,0,0" Foreground="{DynamicResource Color.PanelInfoText}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource Color.PanelInfoBg}" BorderBrush="{DynamicResource Color.PanelInfoBorder}" BorderThickness="1" CornerRadius="10" Padding="9" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="2) 아바타 불러오기" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="OnboardingStep2Text" Text="대기 중" Margin="0,2,0,0" Foreground="{DynamicResource Color.PanelInfoText}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource Color.PanelInfoBg}" BorderBrush="{DynamicResource Color.PanelInfoBorder}" BorderThickness="1" CornerRadius="10" Padding="9">
                                <StackPanel>
                                    <TextBlock Text="3) 출력 시작" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock x:Name="OnboardingStep3Text" Text="대기 중" Margin="0,2,0,0" Foreground="{DynamicResource Color.PanelInfoText}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <Border Background="{DynamicResource Color.PanelInfoAltBg}" BorderBrush="{DynamicResource Color.PanelInfoAltBorder}" BorderThickness="1" CornerRadius="10" Padding="8,6">
                            <TextBlock x:Name="QuickStatusText" Text="세션: 중지 | 아바타: 없음 | 출력: 꺼짐" TextWrapping="Wrap" Foreground="{DynamicResource Color.PanelInfoAltText}" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="{DynamicResource Color.PanelSuccessBg}" BorderBrush="{DynamicResource Color.PanelSuccessBorder}" BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="첫 방송 시작 시간" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelSuccessTitle}"/>
                                <TextBlock x:Name="FirstBroadcastTimingText" Text="최근: 측정 대기" Margin="0,2,0,0" Foreground="{DynamicResource Color.PanelSuccessText}"/>
                                <TextBlock x:Name="FlowMedianTimingText" Text="중앙값(최근 20회): 측정 대기" Margin="0,2,0,0" Foreground="{DynamicResource Color.PanelSuccessText}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ActionBlockReasonPanel" Background="{DynamicResource Color.PanelWarningBg}" BorderBrush="{DynamicResource Color.PanelWarningBorder}" BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="현재 차단 사유" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelWarningText}"/>
                                <TextBlock x:Name="ActionBlockReasonText" Text="없음" TextWrapping="Wrap" Foreground="{DynamicResource Color.PanelWarningText}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BeginnerFailureHintPanel" Visibility="Collapsed" Background="{DynamicResource Color.PanelErrorBg}" BorderBrush="{DynamicResource Color.PanelErrorBorder}" BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="조치가 필요합니다" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelErrorText}" Margin="0,0,0,2"/>
                                <TextBlock x:Name="BeginnerFailureHintText" TextWrapping="Wrap" Foreground="{DynamicResource Color.PanelErrorText}"/>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="RunQuickRecoveryButton" Style="{StaticResource SecondaryButtonStyle}" Content="빠른 복구 실행" Click="RunQuickRecovery_Click" HorizontalAlignment="Left" MinWidth="140"/>
                                    <Button x:Name="OpenDiagnosticsFromHintButton" Style="{StaticResource TertiaryButtonStyle}" Content="고급 진단 열기" Click="OpenDiagnosticsFromHint_Click" HorizontalAlignment="Left" MinWidth="160"/>
                                    <Button x:Name="DismissFailureHintButton" Style="{StaticResource SecondaryButtonStyle}" Content="닫기" Click="DismissFailureHint_Click" Margin="8,0,0,0" HorizontalAlignment="Left" MinWidth="90"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border x:Name="OnboardingRecoveryPanel" Visibility="Collapsed" Background="{DynamicResource Color.PanelWarningBg}" BorderBrush="{DynamicResource Color.PanelWarningBorder}" BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="복구 안내" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelWarningText}"/>
                                <TextBlock x:Name="OnboardingRecoveryText" TextWrapping="Wrap" Foreground="{DynamicResource Color.PanelWarningText}" Margin="0,2,0,0"/>
                                <Button x:Name="DismissRecoveryHintButton" Style="{StaticResource SecondaryButtonStyle}" Content="닫기" Click="DismissFailureHint_Click" Margin="0,8,0,0" HorizontalAlignment="Left" MinWidth="90"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="SessionGroup" Style="{StaticResource SectionCardStyle}" Header="1) 세션" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="세션 시작/종료를 제어합니다." TextWrapping="Wrap" Foreground="{DynamicResource Color.TextMuted}" Margin="0,0,0,8"/>
                        <UniformGrid Columns="2">
                            <Button x:Name="InitializeButton" Content="세션 시작" Click="Initialize_Click" Margin="0,0,4,0"/>
                            <Button x:Name="ShutdownButton" Content="세션 종료" Click="Shutdown_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="4,0,0,0"/>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="AvatarGroup" Style="{StaticResource SectionCardStyle}" Header="2) 아바타" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="아바타 파일 경로" FontWeight="SemiBold"/>
                        <DockPanel Margin="0,4,0,8">
                            <Button x:Name="BrowseAvatarButton" Content="찾아보기..." Click="BrowseAvatar_Click" Width="84" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource TertiaryButtonStyle}"/>
                            <TextBox x:Name="AvatarPathTextBox" Text="..\..\..\..\sample\Kikyo_FT Variant.vrm" TextChanged="InputTextChanged" />
                        </DockPanel>
                        <TextBlock x:Name="AvatarPathValidationText" Foreground="{DynamicResource Color.ValidationErrorText}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Border BorderBrush="{DynamicResource Color.CardSoftBorder}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="132"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="120" Height="120" BorderBrush="{DynamicResource Color.CardSoftBorderStrong}" BorderThickness="1" Background="{DynamicResource Color.CardSoftBg}" CornerRadius="12" VerticalAlignment="Top">
                                    <Image x:Name="AvatarPreviewImage" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="현재 선택 미리보기" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AvatarPreviewStatusText" Text="선택된 파일 없음" Margin="0,4,0,8" TextWrapping="Wrap" Foreground="{DynamicResource Color.TextMuted}"/>
                                    <Button x:Name="RetryAvatarPreviewButton" Content="미리보기 재생성" Click="RetryAvatarPreview_Click" MinWidth="120" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button x:Name="AvatarFacingToggleButton" Content="앞/뒤 전환 (이 아바타 저장)" Click="AvatarFacingToggle_Click" MinWidth="170" Style="{StaticResource TertiaryButtonStyle}"/>
                                        <TextBlock x:Name="AvatarFacingStatusText" Text="저장: 기본" Margin="8,4,0,0" Foreground="{DynamicResource Color.TextMuted}"/>
                                    </WrapPanel>
                                    <TextBlock Text="최근 사용 아바타" FontWeight="SemiBold" Margin="0,10,0,4"/>
                                    <ListBox x:Name="RecentAvatarListBox" Height="160" Padding="4" BorderThickness="1" SelectionChanged="RecentAvatarList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="2"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <UniformGrid Columns="3">
                            <Button x:Name="LoadButton" Content="불러오기" Click="Load_Click" Margin="0,0,4,0"/>
                            <Button x:Name="CancelLoadButton" Content="불러오기 취소" Click="CancelLoad_Click" Margin="4,0,4,0" Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button x:Name="UnloadButton" Content="내리기" Click="Unload_Click" Margin="4,0,0,0" Style="{StaticResource TertiaryButtonStyle}"/>
                        </UniformGrid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="시간 제한" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="LoadTimeoutTextBox" Text="20000"/>
                            <TextBlock Grid.Column="2" Text="ms" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ProgressBar x:Name="LoadProgressBar" Margin="0,8,0,4" Minimum="0" Maximum="100" Height="10" Value="0"/>
                        <Border Background="{DynamicResource Color.PanelInfoAltBg}" BorderBrush="{DynamicResource Color.PanelInfoAltBorder}" BorderThickness="1" CornerRadius="10" Padding="8,4">
                            <TextBlock x:Name="LoadProgressText" Text="불러오기 상태: 대기" Foreground="{DynamicResource Color.TextMuted}" TextWrapping="Wrap"/>
                        </Border>
                        <Border x:Name="AvatarInfoBadgePanel" Visibility="Collapsed" Background="{DynamicResource Color.PanelInfoBg}" BorderBrush="{DynamicResource Color.PanelInfoBorder}" BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,6,0,0">
                            <WrapPanel>
                                <TextBlock Text="표정: " Foreground="{DynamicResource Color.PanelInfoText}" FontSize="11"/>
                                <TextBlock x:Name="AvatarInfoExpressionText" Text="0" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelInfoText}" FontSize="11" Margin="0,0,10,0"/>
                                <TextBlock Text="메시: " Foreground="{DynamicResource Color.PanelInfoText}" FontSize="11"/>
                                <TextBlock x:Name="AvatarInfoMeshText" Text="0" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelInfoText}" FontSize="11" Margin="0,0,10,0"/>
                                <TextBlock Text="형식: " Foreground="{DynamicResource Color.PanelInfoText}" FontSize="11"/>
                                <TextBlock x:Name="AvatarInfoFormatText" Text="-" FontWeight="SemiBold" Foreground="{DynamicResource Color.PanelInfoText}" FontSize="11"/>
                            </WrapPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="RenderGroup" Style="{StaticResource SectionCardStyle}" Header="3) 화면" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <Border BorderBrush="{DynamicResource Color.CardSoftBorder}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="기본" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <CheckBox x:Name="BroadcastModeCheckBox" Content="방송 화면 최적화" Checked="BroadcastMode_Changed" Unchecked="BroadcastMode_Changed" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="카메라" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="CameraModeComboBox" SelectionChanged="CameraMode_SelectionChanged">
                                        <ComboBoxItem Content="자동 전체"/>
                                        <ComboBoxItem Content="자동 상반신"/>
                                        <ComboBoxItem Content="수동"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="구도" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="FramingSlider" Minimum="0.35" Maximum="0.95" Value="0.72" TickFrequency="0.01" IsSnapToTickEnabled="False" ValueChanged="FramingSlider_ValueChanged"/>
