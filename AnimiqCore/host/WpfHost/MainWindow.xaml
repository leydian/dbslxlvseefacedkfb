                </StackPanel>

                <!-- Separator -->
                <Border DockPanel.Dock="Right" Width="1" Background="#40FFFFFF" Margin="8,2"/>

                <!-- OSC toggle -->
                <Button x:Name="QuickOscToggleButton"
                        DockPanel.Dock="Left"
                        Click="QuickOscToggle_Click"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        ToolTip="Ctrl+Shift+O: OSC 모션 출력 토글">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="QuickOscIndicator" Text="○" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="OSC" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Spout toggle -->
                <Button x:Name="QuickSpoutToggleButton"
                        DockPanel.Dock="Left"
                        Click="QuickSpoutToggle_Click"
                        Padding="10,4"
                        Margin="0,0,4,0"
                        ToolTip="Ctrl+Shift+S: Spout 화면 출력 토글">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="QuickSpoutIndicator" Text="○" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Spout" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Padding filler -->
                <Border/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
