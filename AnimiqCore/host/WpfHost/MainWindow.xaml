                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="AutoQualityRecoveryConsecutiveTextBox" Text="240" Margin="0,8,0,0"/>
                        </Grid>
                        <Button Content="자동 품질 정책 적용" Click="ApplyAutoQualityPolicy_Click" MinWidth="170" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </GroupBox>
