<Window x:Class="WpfHost.FloatingAvatarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfHost"
        Title="Animiq — 아바타"
        Width="480" Height="540"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- Render host fills the entire window -->
        <local:RenderHwndHost x:Name="FloatRenderHost"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"/>

        <!-- Top-right overlay: always-on-top checkbox + close button -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,6,8,0"
                    Panel.ZIndex="10">
            <CheckBox x:Name="AlwaysOnTopCheckBox"
                      Content="항상 위"
                      Foreground="#EDE9FE"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Checked="AlwaysOnTop_Changed"
                      Unchecked="AlwaysOnTop_Changed"/>
            <Button Content="✕"
                    Width="28" Height="28"
                    Padding="0"
                    FontSize="12"
                    Background="#40000000"
                    Foreground="#EDE9FE"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#40000000"/>
                        <Setter Property="Foreground" Value="#EDE9FE"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Width="28" Height="28">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="#80DC2626"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="#CCDC2626"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
